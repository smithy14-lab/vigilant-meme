@using CheerDeck.Club.Web.Services
@using CheerDeck.Infrastructure.Identity
@inject ActiveRoleState RoleState

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CheerDeck Club</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        @if (RoleState.IsManagement)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>

            <div class="nav-item px-3 pt-2">
                <small class="text-muted ps-3">PEOPLE</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="athletes">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Athletes
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="guardians">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Guardians
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="coaches">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Coaches
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teams">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Teams
                </NavLink>
            </div>

            <div class="nav-item px-3 pt-2">
                <small class="text-muted ps-3">SCHEDULING</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="venues">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Venues
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="terms">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Terms & Classes
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="classes">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Classes
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="private-lessons">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Private Lessons
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="camps">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Camps
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="attendance">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Attendance
                </NavLink>
            </div>

            <div class="nav-item px-3 pt-2">
                <small class="text-muted ps-3">FINANCE & COMMS</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="invoices">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Invoices
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="messages">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Messages
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="chat">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Chat
                </NavLink>
            </div>

            @if (RoleState.IsInRole(AppRoles.ClubOwner) || RoleState.IsInRole(AppRoles.ClubAdmin))
            {
                <div class="nav-item px-3 pt-2">
                    <small class="text-muted ps-3">ADMIN</small>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="reports">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Reports
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="waivers">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Waivers
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="reminders">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Reminders
                    </NavLink>
                </div>
            }

            @if (RoleState.IsInRole(AppRoles.ClubOwner))
            {
                <div class="nav-item px-3 pt-2">
                    <small class="text-muted ps-3">SETTINGS</small>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="settings">
                        <span class="bi bi-gear-fill" aria-hidden="true"></span> Settings
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="subscription">
                        <span class="bi bi-credit-card" aria-hidden="true"></span> Subscription
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Users
                    </NavLink>
                </div>
            }
        }

        @if (RoleState.IsParent)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="parent" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>
            <div class="nav-item px-3 pt-2">
                <small class="text-muted ps-3">MY FAMILY</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="parent/athletes">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> My Athletes
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="parent/book">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Book a Class
                </NavLink>
            </div>
            <div class="nav-item px-3 pt-2">
                <small class="text-muted ps-3">ACCOUNT</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="parent/invoices">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Invoices & Payments
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="parent/waivers">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Waivers
                </NavLink>
            </div>
        }

        @if (RoleState.IsAthlete)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="my-profile" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> My Profile
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="my-classes">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> My Classes
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="my-team">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> My Team
                </NavLink>
            </div>
        }
    </nav>
</div>
