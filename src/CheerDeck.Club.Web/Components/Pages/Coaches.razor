@page "/coaches"
@attribute [Authorize]
@rendermode InteractiveServer
@inject CoachService CoachService

<PageTitle>Coaches - CheerDeck Club</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Coaches</h1>
    <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
        @(_showForm ? "Cancel" : "Add Coach")
    </button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New Coach</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">First Name</label>
                    <input class="form-control" @bind="_newCoach.FirstName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Last Name</label>
                    <input class="form-control" @bind="_newCoach.LastName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" @bind="_newCoach.Email" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Phone</label>
                    <input class="form-control" @bind="_newCoach.Phone" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CreateCoach" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_coaches.Count == 0)
{
    <div class="alert alert-info">No coaches found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Qualifications</th>
                <th>Credential Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in _coaches)
            {
                <tr>
                    <td>@c.FullName</td>
                    <td>@c.Email</td>
                    <td>@(c.Phone ?? "-")</td>
                    <td>
                        @if (c.Qualifications.Count == 0)
                        {
                            <span class="text-muted">None</span>
                        }
                        else
                        {
                            @foreach (var q in c.Qualifications)
                            {
                                <span class="badge bg-light text-dark border me-1">@q.QualificationType</span>
                            }
                        }
                    </td>
                    <td>
                        @{ var status = GetCredentialStatus(c); }
                        <span class="badge @status.Css">@status.Label</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private List<Coach> _coaches = new();
    private Coach _newCoach = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCoaches();
    }

    private async Task LoadCoaches()
    {
        _loading = true;
        _coaches = await CoachService.GetAllAsync();
        _loading = false;
    }

    private async Task CreateCoach()
    {
        if (string.IsNullOrWhiteSpace(_newCoach.FirstName) || string.IsNullOrWhiteSpace(_newCoach.LastName)
            || string.IsNullOrWhiteSpace(_newCoach.Email))
            return;

        _saving = true;
        await CoachService.CreateAsync(_newCoach);
        _newCoach = new Coach();
        _showForm = false;
        _saving = false;
        await LoadCoaches();
    }

    private (string Css, string Label) GetCredentialStatus(Coach coach)
    {
        if (coach.Qualifications.Count == 0)
            return ("bg-secondary", "No credentials");

        if (coach.Qualifications.Any(q => q.IsExpired))
            return ("bg-danger", "Expired");

        if (coach.Qualifications.Any(q => q.IsExpiringSoon))
            return ("bg-warning text-dark", "Expiring soon");

        return ("bg-success", "Valid");
    }
}
