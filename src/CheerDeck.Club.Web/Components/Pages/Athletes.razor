@page "/athletes"
@rendermode InteractiveServer
@inject AthleteService AthleteService

<PageTitle>Athletes - CheerDeck Club</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Athletes</h1>
    <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
        @(_showForm ? "Cancel" : "Add Athlete")
    </button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New Athlete</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">First Name</label>
                    <input class="form-control" @bind="_newAthlete.FirstName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Last Name</label>
                    <input class="form-control" @bind="_newAthlete.LastName" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Date of Birth</label>
                    <input type="date" class="form-control" @bind="_dobInput" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Level</label>
                    <select class="form-select" @bind="_newAthlete.Level">
                        @foreach (var level in Enum.GetValues<CheerLevel>())
                        {
                            <option value="@level">@level</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CreateAthlete" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<div class="mb-3">
    <input class="form-control" placeholder="Search athletes..." @bind="_searchQuery" @bind:event="oninput" @bind:after="FilterAthletes" />
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_filtered.Count == 0)
{
    <div class="alert alert-info">No athletes found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Date of Birth</th>
                <th>Level</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in _filtered)
            {
                <tr>
                    <td>@a.FullName</td>
                    <td>@a.DateOfBirth.ToString("dd MMM yyyy")</td>
                    <td>@a.Level</td>
                    <td>
                        <span class="badge @(a.IsActive ? "bg-success" : "bg-secondary")">
                            @(a.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td><a href="athletes/@a.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private string _searchQuery = string.Empty;
    private List<Athlete> _athletes = new();
    private List<Athlete> _filtered = new();
    private Athlete _newAthlete = new();
    private DateTime _dobInput = DateTime.Today.AddYears(-8);

    protected override async Task OnInitializedAsync()
    {
        await LoadAthletes();
    }

    private async Task LoadAthletes()
    {
        _loading = true;
        _athletes = await AthleteService.GetAllAsync();
        FilterAthletes();
        _loading = false;
    }

    private void FilterAthletes()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _filtered = _athletes;
        }
        else
        {
            var q = _searchQuery.Trim().ToLowerInvariant();
            _filtered = _athletes.Where(a =>
                a.FullName.Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private async Task CreateAthlete()
    {
        if (string.IsNullOrWhiteSpace(_newAthlete.FirstName) || string.IsNullOrWhiteSpace(_newAthlete.LastName))
            return;

        _saving = true;
        _newAthlete.DateOfBirth = DateOnly.FromDateTime(_dobInput);
        await AthleteService.CreateAsync(_newAthlete);
        _newAthlete = new Athlete();
        _dobInput = DateTime.Today.AddYears(-8);
        _showForm = false;
        _saving = false;
        await LoadAthletes();
    }
}
