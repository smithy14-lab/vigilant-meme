@page "/subscription"
@attribute [Authorize(Roles = "ClubOwner")]
@rendermode InteractiveServer
@inject ITenantContext TenantContext
@inject AppDbContext Db
@inject IPaymentGateway Payments
@inject NavigationManager Nav

<PageTitle>Subscription - CheerDeck Club</PageTitle>

<h1 class="mb-4">Subscription & Billing</h1>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_tenant is null)
{
    <div class="alert alert-danger">Club not found.</div>
}
else
{
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @_message
            <button type="button" class="btn-close" @onclick="() => _message = null"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">Current Plan</div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-1">@_tenant.Plan</h3>
                            @if (_tenant.IsLinkedToCompetitions)
                            {
                                <span class="badge bg-success">Free via CheerDeck Competitions</span>
                            }
                            else if (_tenant.SubscriptionStatus == SubscriptionStatus.Active)
                            {
                                <span class="badge bg-success">Active</span>
                                @if (_tenant.SubscriptionEndDate.HasValue)
                                {
                                    <small class="text-muted ms-2">Renews @_tenant.SubscriptionEndDate.Value.ToString("dd MMM yyyy")</small>
                                }
                            }
                            else if (_tenant.SubscriptionStatus == SubscriptionStatus.Trialing)
                            {
                                <span class="badge bg-info">Trial</span>
                                @if (_tenant.TrialEndDate.HasValue)
                                {
                                    <small class="text-muted ms-2">Trial ends @_tenant.TrialEndDate.Value.ToString("dd MMM yyyy")</small>
                                }
                            }
                            else if (_tenant.SubscriptionStatus == SubscriptionStatus.PastDue)
                            {
                                <span class="badge bg-warning">Past Due</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No Active Subscription</span>
                            }
                        </div>
                        @if (_tenant.SubscriptionStatus == SubscriptionStatus.Active && !_tenant.IsLinkedToCompetitions)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="CancelSubscriptionAsync" disabled="@_processing">Cancel</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!_tenant.IsLinkedToCompetitions)
    {
        <h4 class="mb-3">Choose a Plan</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card @(_tenant.Plan == SubscriptionPlan.Starter ? "border-primary" : "")">
                    <div class="card-header text-center fw-bold">Starter</div>
                    <div class="card-body text-center">
                        <h2 class="mb-0">&pound;19<small class="text-muted fs-6">/month</small></h2>
                        <p class="text-muted mt-2">Perfect for small clubs</p>
                        <ul class="list-unstyled text-start">
                            <li>Up to 50 athletes</li>
                            <li>5 classes per week</li>
                            <li>Basic reporting</li>
                            <li>Email messaging</li>
                            <li>Attendance tracking</li>
                        </ul>
                        @if (_tenant.Plan != SubscriptionPlan.Starter)
                        {
                            <button class="btn btn-primary w-100" @onclick="() => SelectPlanAsync(SubscriptionPlan.Starter)" disabled="@_processing">
                                @(_tenant.Plan == SubscriptionPlan.Free ? "Start Free Trial" : "Switch Plan")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary w-100" disabled>Current Plan</button>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card @(_tenant.Plan == SubscriptionPlan.Growth ? "border-primary" : "")">
                    <div class="card-header text-center fw-bold bg-primary text-white">Growth <span class="badge bg-warning text-dark ms-1">Popular</span></div>
                    <div class="card-body text-center">
                        <h2 class="mb-0">&pound;39<small class="text-muted fs-6">/month</small></h2>
                        <p class="text-muted mt-2">For growing clubs</p>
                        <ul class="list-unstyled text-start">
                            <li>Up to 200 athletes</li>
                            <li>Unlimited classes</li>
                            <li>Advanced reporting</li>
                            <li>Parent portal</li>
                            <li>Online payments</li>
                            <li>Waivers & consent</li>
                            <li>Chat & messaging</li>
                        </ul>
                        @if (_tenant.Plan != SubscriptionPlan.Growth)
                        {
                            <button class="btn btn-primary w-100" @onclick="() => SelectPlanAsync(SubscriptionPlan.Growth)" disabled="@_processing">
                                @(_tenant.Plan == SubscriptionPlan.Free ? "Start Free Trial" : "Switch Plan")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary w-100" disabled>Current Plan</button>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card @(_tenant.Plan == SubscriptionPlan.Professional ? "border-primary" : "")">
                    <div class="card-header text-center fw-bold">Professional</div>
                    <div class="card-body text-center">
                        <h2 class="mb-0">&pound;69<small class="text-muted fs-6">/month</small></h2>
                        <p class="text-muted mt-2">For established programmes</p>
                        <ul class="list-unstyled text-start">
                            <li>Unlimited athletes</li>
                            <li>Unlimited classes</li>
                            <li>Full reporting suite</li>
                            <li>Private lessons & camps</li>
                            <li>Automated reminders</li>
                            <li>Custom branding</li>
                            <li>Priority support</li>
                        </ul>
                        @if (_tenant.Plan != SubscriptionPlan.Professional)
                        {
                            <button class="btn btn-primary w-100" @onclick="() => SelectPlanAsync(SubscriptionPlan.Professional)" disabled="@_processing">
                                @(_tenant.Plan == SubscriptionPlan.Free ? "Start Free Trial" : "Switch Plan")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary w-100" disabled>Current Plan</button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 p-3 bg-light rounded">
            <p class="mb-0"><strong>Using CheerDeck Competitions?</strong> Clubs registered for events through CheerDeck Competitions get free access to CheerDeck Club. <a href="https://competitions.cheerdeck.com" target="_blank">Learn more</a></p>
        </div>
    }
}

@code {
    private bool _loading = true;
    private bool _processing;
    private Tenant? _tenant;
    private string? _message;
    private bool _isError;

    private static readonly Dictionary<SubscriptionPlan, string> PriceIds = new()
    {
        [SubscriptionPlan.Starter] = "price_starter",
        [SubscriptionPlan.Growth] = "price_growth",
        [SubscriptionPlan.Professional] = "price_professional"
    };

    private static readonly Dictionary<SubscriptionPlan, decimal> Prices = new()
    {
        [SubscriptionPlan.Starter] = 19m,
        [SubscriptionPlan.Growth] = 39m,
        [SubscriptionPlan.Professional] = 69m
    };

    protected override async Task OnInitializedAsync()
    {
        _tenant = await Db.Tenants.FindAsync(TenantContext.TenantId);
        _loading = false;
    }

    private async Task SelectPlanAsync(SubscriptionPlan plan)
    {
        if (_tenant is null || !PriceIds.TryGetValue(plan, out var priceId)) return;

        _processing = true;
        _message = null;
        try
        {
            var customerId = _tenant.StripeCustomerId ?? _tenant.Id.ToString();
            var result = await Payments.CreateSubscriptionAsync(
                customerId, priceId,
                new Dictionary<string, string>
                {
                    ["tenantId"] = _tenant.Id.ToString(),
                    ["plan"] = plan.ToString()
                });

            if (result.Success)
            {
                _tenant.Plan = plan;
                _tenant.SubscriptionStatus = SubscriptionStatus.Active;
                _tenant.StripeSubscriptionId = result.SubscriptionId;
                _tenant.SubscriptionStartDate = DateTime.UtcNow;
                _tenant.SubscriptionEndDate = DateTime.UtcNow.AddMonths(1);
                _tenant.UpdatedAt = DateTime.UtcNow;

                if (_tenant.Plan == SubscriptionPlan.Free || _tenant.SubscriptionStatus == SubscriptionStatus.None)
                {
                    _tenant.SubscriptionStatus = SubscriptionStatus.Trialing;
                    _tenant.TrialEndDate = DateTime.UtcNow.AddDays(14);
                }

                await Db.SaveChangesAsync();
                _message = $"Successfully subscribed to {plan} plan!";
                _isError = false;
            }
            else
            {
                _message = $"Failed to create subscription: {result.FailureReason}";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task CancelSubscriptionAsync()
    {
        if (_tenant is null || string.IsNullOrEmpty(_tenant.StripeSubscriptionId)) return;

        _processing = true;
        _message = null;
        try
        {
            var result = await Payments.CancelSubscriptionAsync(_tenant.StripeSubscriptionId);
            if (result.Success)
            {
                _tenant.SubscriptionStatus = SubscriptionStatus.Cancelled;
                _tenant.UpdatedAt = DateTime.UtcNow;
                await Db.SaveChangesAsync();
                _message = "Subscription cancelled. You'll retain access until the end of your billing period.";
                _isError = false;
            }
            else
            {
                _message = $"Failed to cancel: {result.FailureReason}";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _processing = false;
        }
    }
}
