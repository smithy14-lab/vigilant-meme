@page "/classes"
@rendermode InteractiveServer
@inject ClassService ClassService
@inject VenueService VenueService
@inject TermService TermService

<PageTitle>Classes - CheerDeck Club</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Classes</h1>
    <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
        @(_showForm ? "Cancel" : "Add Class")
    </button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New Class</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="_newClass.Name" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Day</label>
                    <select class="form-select" @bind="_newClass.DayOfWeek">
                        @foreach (var d in Enum.GetValues<DayOfWeekEnum>())
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Start Time</label>
                    <input type="time" class="form-control" @bind="_startTimeInput" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">End Time</label>
                    <input type="time" class="form-control" @bind="_endTimeInput" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">Capacity</label>
                    <input type="number" class="form-control" @bind="_newClass.Capacity" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Level</label>
                    <select class="form-select" @bind="_selectedLevel">
                        <option value="">Any</option>
                        @foreach (var level in Enum.GetValues<CheerLevel>())
                        {
                            <option value="@level">@level</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label">Venue</label>
                    <select class="form-select" @bind="_selectedVenueId">
                        <option value="">-- None --</option>
                        @foreach (var v in _venues)
                        {
                            <option value="@v.Id">@v.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Term</label>
                    <select class="form-select" @bind="_selectedTermId">
                        <option value="">-- None --</option>
                        @foreach (var t in _terms)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Price / Session</label>
                    <input type="number" step="0.01" class="form-control" @bind="_newClass.PricePerSession" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Term Price</label>
                    <input type="number" step="0.01" class="form-control" @bind="_newClass.TermPrice" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CreateClass" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_classes.Count == 0)
{
    <div class="alert alert-info">No classes found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Venue</th>
                <th>Day</th>
                <th>Time</th>
                <th>Level</th>
                <th>Enrolled / Capacity</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in _classes)
            {
                var enrolled = c.Enrolments.Count(e => e.Status == EnrolmentStatus.Active);
                <tr>
                    <td>@c.Name</td>
                    <td>@(c.Venue?.Name ?? "-")</td>
                    <td>@c.DayOfWeek</td>
                    <td>@c.StartTime.ToString("HH:mm") - @c.EndTime.ToString("HH:mm")</td>
                    <td>@(c.Level?.ToString() ?? "Any")</td>
                    <td>
                        <span class="@(enrolled >= c.Capacity ? "text-danger fw-bold" : "")">@enrolled / @c.Capacity</span>
                    </td>
                    <td><a href="/classes/@c.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private List<Class> _classes = new();
    private List<Venue> _venues = new();
    private List<Term> _terms = new();
    private Class _newClass = new();
    private string _selectedVenueId = string.Empty;
    private string _selectedTermId = string.Empty;
    private string _selectedLevel = string.Empty;
    private DateTime _startTimeInput = DateTime.Today.AddHours(17);
    private DateTime _endTimeInput = DateTime.Today.AddHours(18);

    protected override async Task OnInitializedAsync()
    {
        _venues = await VenueService.GetAllAsync();
        _terms = await TermService.GetAllAsync();
        await LoadClasses();
    }

    private async Task LoadClasses()
    {
        _loading = true;
        _classes = await ClassService.GetAllAsync();
        _loading = false;
    }

    private async Task CreateClass()
    {
        if (string.IsNullOrWhiteSpace(_newClass.Name))
            return;

        _saving = true;
        _newClass.StartTime = TimeOnly.FromDateTime(_startTimeInput);
        _newClass.EndTime = TimeOnly.FromDateTime(_endTimeInput);

        if (Guid.TryParse(_selectedVenueId, out var venueId))
            _newClass.VenueId = venueId;

        if (Guid.TryParse(_selectedTermId, out var termId))
            _newClass.TermId = termId;

        if (!string.IsNullOrEmpty(_selectedLevel) && Enum.TryParse<CheerLevel>(_selectedLevel, out var level))
            _newClass.Level = level;

        await ClassService.CreateAsync(_newClass);
        _newClass = new Class();
        _selectedVenueId = string.Empty;
        _selectedTermId = string.Empty;
        _selectedLevel = string.Empty;
        _startTimeInput = DateTime.Today.AddHours(17);
        _endTimeInput = DateTime.Today.AddHours(18);
        _showForm = false;
        _saving = false;
        await LoadClasses();
    }
}
