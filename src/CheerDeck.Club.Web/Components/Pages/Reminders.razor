@page "/reminders"
@rendermode InteractiveServer
@inject ReminderService ReminderService

<PageTitle>Reminders - CheerDeck Club</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Automated Reminders</h1>
    <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
        @(_showForm ? "Cancel" : "Create Reminder")
    </button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New Reminder</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="_newReminder.Name" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select class="form-select" @bind="_newReminder.Type">
                        @foreach (var t in Enum.GetValues<ReminderType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Channel</label>
                    <select class="form-select" @bind="_newReminder.Channel">
                        @foreach (var ch in Enum.GetValues<ReminderChannel>())
                        {
                            <option value="@ch">@ch</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Days Before</label>
                    <input type="number" class="form-control" @bind="_newReminder.DaysBefore" />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="form-label">Subject</label>
                    <input class="form-control" @bind="_newReminder.Subject" />
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="isRecurring" @bind="_newReminder.IsRecurring" />
                        <label class="form-check-label" for="isRecurring">Is Recurring</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Interval (days)</label>
                    <input type="number" class="form-control" @bind="_newReminder.RecurringIntervalDays" disabled="@(!_newReminder.IsRecurring)" />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-12">
                    <label class="form-label">Body</label>
                    <textarea class="form-control" rows="4" @bind="_newReminder.Body"></textarea>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CreateReminder" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_reminders.Count == 0)
{
    <div class="alert alert-info">No reminders found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Channel</th>
                <th>Status</th>
                <th>Days Before</th>
                <th>Logs</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _reminders)
            {
                <tr>
                    <td>@r.Name</td>
                    <td>@r.Type</td>
                    <td>@r.Channel</td>
                    <td>
                        <span class="badge @GetStatusBadge(r.Status)">@r.Status</span>
                    </td>
                    <td>@r.DaysBefore</td>
                    <td>@r.Logs.Count</td>
                    <td>
                        @if (r.Status == ReminderStatus.Active)
                        {
                            <button class="btn btn-sm btn-warning" @onclick="() => UpdateStatus(r.Id, ReminderStatus.Paused)" disabled="@_saving">
                                Pause
                            </button>
                        }
                        else if (r.Status == ReminderStatus.Paused)
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => UpdateStatus(r.Id, ReminderStatus.Active)" disabled="@_saving">
                                Resume
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private List<AutomatedReminder> _reminders = new();
    private AutomatedReminder _newReminder = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadReminders();
    }

    private async Task LoadReminders()
    {
        _loading = true;
        _reminders = await ReminderService.GetAllAsync();
        _loading = false;
    }

    private async Task CreateReminder()
    {
        if (string.IsNullOrWhiteSpace(_newReminder.Name))
            return;

        _saving = true;
        await ReminderService.CreateAsync(_newReminder);
        _newReminder = new AutomatedReminder();
        _showForm = false;
        _saving = false;
        await LoadReminders();
    }

    private async Task UpdateStatus(Guid reminderId, ReminderStatus status)
    {
        _saving = true;
        await ReminderService.UpdateStatusAsync(reminderId, status);
        _saving = false;
        await LoadReminders();
    }

    private static string GetStatusBadge(ReminderStatus status) => status switch
    {
        ReminderStatus.Active => "bg-success",
        ReminderStatus.Paused => "bg-warning text-dark",
        ReminderStatus.Completed => "bg-dark",
        ReminderStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };
}
