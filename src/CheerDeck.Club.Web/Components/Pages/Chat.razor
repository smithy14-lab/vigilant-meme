@page "/chat"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject ChatService ChatService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthState
@implements IAsyncDisposable

<PageTitle>Chat - CheerDeck Club</PageTitle>

<h1 class="mb-4">Chat</h1>

<div class="d-flex" style="height: calc(100vh - 250px);">
    @* Left panel: Room list *@
    <div class="border rounded-start p-0 d-flex flex-column" style="width: 300px; min-width: 300px;">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <strong>Rooms</strong>
            <button class="btn btn-sm btn-primary" @onclick="() => _showNewRoom = !_showNewRoom">
                @(_showNewRoom ? "Cancel" : "New Room")
            </button>
        </div>

        @if (_showNewRoom)
        {
            <div class="p-3 border-bottom bg-light">
                <div class="mb-2">
                    <input class="form-control form-control-sm" placeholder="Room name" @bind="_newRoomName" />
                </div>
                <div class="mb-2">
                    <select class="form-select form-select-sm" @bind="_newRoomType">
                        <option value="@ChatRoomType.Club">Club</option>
                        <option value="@ChatRoomType.Class">Class</option>
                        <option value="@ChatRoomType.Team">Team</option>
                        <option value="@ChatRoomType.CoachesOnly">Coaches Only</option>
                    </select>
                </div>
                <button class="btn btn-success btn-sm w-100" @onclick="CreateRoom" disabled="@_creatingRoom">
                    @if (_creatingRoom) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Create
                </button>
            </div>
        }

        <div class="flex-grow-1 overflow-auto">
            @if (_loadingRooms)
            {
                <div class="d-flex justify-content-center py-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (_rooms.Count == 0)
            {
                <div class="text-muted text-center py-4 small">No rooms found.</div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var room in _rooms)
                    {
                        var isSelected = _selectedRoom?.Id == room.Id;
                        <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-start @(isSelected ? "active" : "")"
                                @onclick="() => SelectRoom(room)">
                            <div class="me-auto text-truncate">
                                <div class="fw-semibold text-truncate">@room.Name</div>
                                <small class="@(isSelected ? "text-white-50" : "text-muted")">
                                    <span class="badge @GetRoomTypeBadge(room.Type) me-1">@room.Type</span>
                                    @room.Members.Count member@(room.Members.Count != 1 ? "s" : "")
                                </small>
                            </div>
                            @if (HasUnread(room))
                            {
                                <span class="badge bg-danger rounded-pill align-self-center">New</span>
                            }
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    @* Right panel: Messages *@
    <div class="border border-start-0 rounded-end flex-grow-1 d-flex flex-column">
        @if (_selectedRoom is null)
        {
            <div class="flex-grow-1 d-flex align-items-center justify-content-center text-muted">
                Select a room to start chatting
            </div>
        }
        else
        {
            @* Room header *@
            <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center">
                <div>
                    <strong>@_selectedRoom.Name</strong>
                    <span class="text-muted small ms-2">@_selectedRoom.Members.Count member@(_selectedRoom.Members.Count != 1 ? "s" : "")</span>
                </div>
                <span class="badge @GetRoomTypeBadge(_selectedRoom.Type)">@_selectedRoom.Type</span>
            </div>

            @* Message list *@
            <div class="flex-grow-1 overflow-auto p-3" style="background-color: #f8f9fa;">
                @if (_loadingMessages)
                {
                    <div class="d-flex justify-content-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (_messages.Count == 0)
                {
                    <div class="text-muted text-center py-4">No messages yet. Start the conversation!</div>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        var isOwn = msg.SenderUserId == _currentUserId;
                        <div class="d-flex mb-2 @(isOwn ? "justify-content-end" : "justify-content-start")">
                            <div class="p-2 rounded shadow-sm" style="max-width: 70%; @(isOwn ? "background-color: #d1e7dd;" : "background-color: #ffffff;")">
                                @if (!isOwn)
                                {
                                    <div class="fw-semibold small text-primary">@msg.SenderName</div>
                                }
                                <div>@msg.Content</div>
                                <div class="text-muted small text-end mt-1">@msg.SentAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                }
            </div>

            @* Message input *@
            <div class="p-3 border-top bg-white">
                <div class="input-group">
                    <input class="form-control" placeholder="Type a message..."
                           @bind="_messageContent" @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                    <button class="btn btn-primary" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(_messageContent) || _sending)">
                        @if (_sending) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Send
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private HubConnection? _hubConnection;
    private List<ChatRoom> _rooms = new();
    private List<ChatMessage> _messages = new();
    private ChatRoom? _selectedRoom;
    private string _currentUserId = string.Empty;

    private bool _loadingRooms = true;
    private bool _loadingMessages;
    private bool _sending;
    private bool _showNewRoom;
    private bool _creatingRoom;

    private string _messageContent = string.Empty;
    private string _newRoomName = string.Empty;
    private ChatRoomType _newRoomType = ChatRoomType.Club;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        var hubUrl = NavigationManager.ToAbsoluteUri("/hubs/chat");
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, string, DateTime>("ReceiveMessage", (senderName, content, sentAt) =>
        {
            var message = new ChatMessage
            {
                SenderName = senderName,
                Content = content,
                SentAt = sentAt,
                SenderUserId = string.Empty
            };
            _messages.Add(message);
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await LoadRooms();
    }

    private async Task LoadRooms()
    {
        _loadingRooms = true;
        _rooms = await ChatService.GetRoomsForUserAsync(_currentUserId);
        _loadingRooms = false;
    }

    private async Task SelectRoom(ChatRoom room)
    {
        if (_selectedRoom?.Id == room.Id) return;

        // Leave previous room group
        if (_selectedRoom is not null && _hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("LeaveRoom", _selectedRoom.Id.ToString());
        }

        _selectedRoom = room;
        _messageContent = string.Empty;

        // Join new room group
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("JoinRoom", room.Id.ToString());
        }

        // Load messages
        _loadingMessages = true;
        _messages = await ChatService.GetMessagesAsync(room.Id);
        _loadingMessages = false;

        // Mark as read
        await ChatService.MarkReadAsync(room.Id, _currentUserId);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_messageContent) || _selectedRoom is null)
            return;

        _sending = true;
        var content = _messageContent;
        _messageContent = string.Empty;

        var saved = await ChatService.SendMessageAsync(_selectedRoom.Id, content);

        // Broadcast via SignalR
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SendMessage", _selectedRoom.Id.ToString(), saved.SenderName, saved.Content);
        }

        // Add to local list so we see our own message immediately
        if (!_messages.Any(m => m.Id == saved.Id))
        {
            _messages.Add(saved);
        }

        _sending = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task CreateRoom()
    {
        if (string.IsNullOrWhiteSpace(_newRoomName)) return;

        _creatingRoom = true;
        var room = new ChatRoom
        {
            Name = _newRoomName.Trim(),
            Type = _newRoomType
        };
        await ChatService.CreateRoomAsync(room);

        _newRoomName = string.Empty;
        _newRoomType = ChatRoomType.Club;
        _showNewRoom = false;
        _creatingRoom = false;
        await LoadRooms();
    }

    private bool HasUnread(ChatRoom room)
    {
        var member = room.Members.FirstOrDefault(m => m.UserId == _currentUserId);
        if (member is null) return false;
        return member.LastReadAt is null || room.Messages.Any(m => m.SentAt > member.LastReadAt);
    }

    private static string GetRoomTypeBadge(ChatRoomType type) => type switch
    {
        ChatRoomType.Club => "bg-primary",
        ChatRoomType.Class => "bg-info",
        ChatRoomType.Team => "bg-success",
        ChatRoomType.DirectMessage => "bg-secondary",
        ChatRoomType.CoachesOnly => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            if (_selectedRoom is not null)
            {
                try
                {
                    await _hubConnection.InvokeAsync("LeaveRoom", _selectedRoom.Id.ToString());
                }
                catch
                {
                    // Connection may already be closed
                }
            }
            await _hubConnection.DisposeAsync();
        }
    }
}
