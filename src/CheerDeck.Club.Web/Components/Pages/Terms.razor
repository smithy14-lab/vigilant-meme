@page "/terms"
@rendermode InteractiveServer
@inject TermService TermService

<PageTitle>Terms - CheerDeck Club</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Terms</h1>
    <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
        @(_showForm ? "Cancel" : "Add Term")
    </button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New Term</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="_newTerm.Name" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-control" @bind="_startInput" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-control" @bind="_endInput" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CreateTerm" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDuplicate)
{
    <div class="card mb-4 border-info">
        <div class="card-body">
            <h5 class="card-title">Duplicate Term: @_duplicateSourceName</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">New Term Name</label>
                    <input class="form-control" @bind="_dupName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-control" @bind="_dupStartInput" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-control" @bind="_dupEndInput" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="btn-group w-100">
                        <button class="btn btn-info" @onclick="DuplicateTerm" disabled="@_saving">Duplicate</button>
                        <button class="btn btn-outline-secondary" @onclick="() => _showDuplicate = false">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_terms.Count == 0)
{
    <div class="alert alert-info">No terms found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in _terms)
            {
                <tr>
                    <td>@t.Name</td>
                    <td>@t.StartDate.ToString("dd MMM yyyy")</td>
                    <td>@t.EndDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">
                            @(t.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-info" @onclick="() => ShowDuplicate(t)">Duplicate</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _showDuplicate;
    private bool _saving;
    private List<Term> _terms = new();
    private Term _newTerm = new();
    private DateTime _startInput = DateTime.Today;
    private DateTime _endInput = DateTime.Today.AddMonths(3);

    private Guid _duplicateSourceId;
    private string _duplicateSourceName = string.Empty;
    private string _dupName = string.Empty;
    private DateTime _dupStartInput = DateTime.Today;
    private DateTime _dupEndInput = DateTime.Today.AddMonths(3);

    protected override async Task OnInitializedAsync()
    {
        await LoadTerms();
    }

    private async Task LoadTerms()
    {
        _loading = true;
        _terms = await TermService.GetAllAsync();
        _loading = false;
    }

    private async Task CreateTerm()
    {
        if (string.IsNullOrWhiteSpace(_newTerm.Name))
            return;

        _saving = true;
        _newTerm.StartDate = DateOnly.FromDateTime(_startInput);
        _newTerm.EndDate = DateOnly.FromDateTime(_endInput);
        await TermService.CreateAsync(_newTerm);
        _newTerm = new Term();
        _startInput = DateTime.Today;
        _endInput = DateTime.Today.AddMonths(3);
        _showForm = false;
        _saving = false;
        await LoadTerms();
    }

    private void ShowDuplicate(Term source)
    {
        _duplicateSourceId = source.Id;
        _duplicateSourceName = source.Name;
        _dupName = $"{source.Name} (Copy)";
        _dupStartInput = DateTime.Today;
        _dupEndInput = DateTime.Today.AddMonths(3);
        _showDuplicate = true;
    }

    private async Task DuplicateTerm()
    {
        if (string.IsNullOrWhiteSpace(_dupName))
            return;

        _saving = true;
        await TermService.DuplicateAsync(
            _duplicateSourceId,
            _dupName,
            DateOnly.FromDateTime(_dupStartInput),
            DateOnly.FromDateTime(_dupEndInput));
        _showDuplicate = false;
        _saving = false;
        await LoadTerms();
    }
}
