@page "/account/forgot-password"
@layout LoginLayout

<PageTitle>Forgot Password - CheerDeck Club</PageTitle>

@if (!string.IsNullOrEmpty(Status))
{
    @if (Status == "Sent")
    {
        <div class="alert alert-success">
            If an account exists with that email, a password reset link has been sent. Please check your inbox.
        </div>
    }
    else
    {
        <div class="alert alert-danger">Something went wrong. Please try again.</div>
    }
}

<form method="post" action="/account/perform-forgot-password">
    <div class="mb-3">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-control" placeholder="you@example.com" required autofocus />
        <div class="form-text">Enter the email associated with your account and we'll send you a reset link.</div>
    </div>
    <button type="submit" class="btn btn-primary w-100 mb-3">Send Reset Link</button>
</form>

<div class="text-center">
    <a href="/account/login">Back to Login</a>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Status { get; set; }
}
