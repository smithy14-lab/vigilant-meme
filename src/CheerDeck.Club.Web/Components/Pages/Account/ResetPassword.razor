@page "/account/reset-password"
@layout LoginLayout

<PageTitle>Reset Password - CheerDeck Club</PageTitle>

@if (!string.IsNullOrEmpty(Status))
{
    @if (Status == "Success")
    {
        <div class="alert alert-success">
            Your password has been reset successfully. <a href="/account/login">Sign in</a> with your new password.
        </div>
    }
    else if (Status == "InvalidToken")
    {
        <div class="alert alert-danger">
            The reset link is invalid or has expired. Please <a href="/account/forgot-password">request a new one</a>.
        </div>
    }
    else if (Status == "PasswordMismatch")
    {
        <div class="alert alert-danger">Passwords do not match.</div>
    }
    else
    {
        <div class="alert alert-danger">@Status</div>
    }
}

@if (Status != "Success")
{
    <form method="post" action="/account/perform-reset-password">
        <input type="hidden" name="email" value="@Email" />
        <input type="hidden" name="token" value="@Token" />
        <div class="mb-3">
            <label class="form-label">New Password</label>
            <input type="password" name="password" class="form-control" required minlength="6" />
            <div class="form-text">At least 6 characters, including uppercase, lowercase, digit, and special character.</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
        </div>
        <button type="submit" class="btn btn-primary w-100 mb-3">Reset Password</button>
    </form>
}

<div class="text-center">
    <a href="/account/login">Back to Login</a>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    [SupplyParameterFromQuery]
    public string? Status { get; set; }
}
