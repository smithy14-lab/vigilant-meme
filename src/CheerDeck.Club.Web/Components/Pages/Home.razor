@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@using CheerDeck.Club.Web.Services
@inject ActiveRoleState RoleState
@inject NavigationManager Navigation
@inject AthleteService AthleteService
@inject ClassService ClassService
@inject InvoiceService InvoiceService

<PageTitle>Dashboard - CheerDeck Club</PageTitle>

@if (_redirecting)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <h1 class="mb-4">Dashboard</h1>

    @if (_loading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card text-bg-primary">
                    <div class="card-body">
                        <h6 class="card-title">Athletes</h6>
                        <h2 class="mb-0">@_athleteCount</h2>
                        <small>active athletes</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-bg-success">
                    <div class="card-body">
                        <h6 class="card-title">Classes</h6>
                        <h2 class="mb-0">@_classCount</h2>
                        <small>active classes</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Upcoming Sessions</h6>
                        <h2 class="mb-0">@_upcomingSessionCount</h2>
                        <small>this week</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-bg-warning">
                    <div class="card-body">
                        <h6 class="card-title">Revenue</h6>
                        <h2 class="mb-0">@_revenue.ToString("C")</h2>
                        <small>paid invoices</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">Recent Athletes</div>
                    <div class="card-body p-0">
                        @if (_recentAthletes.Count == 0)
                        {
                            <p class="text-muted p-3 mb-0">No athletes yet.</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr><th>Name</th><th>Level</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in _recentAthletes)
                                    {
                                        <tr>
                                            <td><a href="athletes/@a.Id">@a.FullName</a></td>
                                            <td>@a.Level</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">Recent Invoices</div>
                    <div class="card-body p-0">
                        @if (_recentInvoices.Count == 0)
                        {
                            <p class="text-muted p-3 mb-0">No invoices yet.</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr><th>Invoice #</th><th>Total</th><th>Status</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var inv in _recentInvoices)
                                    {
                                        <tr>
                                            <td>@inv.InvoiceNumber</td>
                                            <td>@inv.Total.ToString("C")</td>
                                            <td><span class="badge @GetInvoiceStatusBadge(inv.Status)">@inv.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private bool _redirecting;
    private bool _loading = true;
    private int _athleteCount;
    private int _classCount;
    private int _upcomingSessionCount;
    private decimal _revenue;
    private List<Athlete> _recentAthletes = new();
    private List<Invoice> _recentInvoices = new();

    protected override async Task OnInitializedAsync()
    {
        if (RoleState.IsParent)
        {
            _redirecting = true;
            Navigation.NavigateTo("/parent", replace: true);
            return;
        }
        if (RoleState.IsAthlete)
        {
            _redirecting = true;
            Navigation.NavigateTo("/my-profile", replace: true);
            return;
        }

        var athletes = await AthleteService.GetAllAsync();
        var classes = await ClassService.GetAllAsync();
        var invoices = await InvoiceService.GetAllAsync();

        _athleteCount = athletes.Count;
        _classCount = classes.Count;
        _upcomingSessionCount = classes.SelectMany(c => c.Sessions ?? (IEnumerable<ClassSession>)[])
            .Count(s => !s.IsCancelled && s.Date >= DateOnly.FromDateTime(DateTime.UtcNow)
                        && s.Date <= DateOnly.FromDateTime(DateTime.UtcNow.AddDays(7)));
        _revenue = invoices.Where(i => i.Status == InvoiceStatus.Paid).Sum(i => i.Total);
        _recentAthletes = athletes.Take(5).ToList();
        _recentInvoices = invoices.Take(5).ToList();

        _loading = false;
    }

    private string GetInvoiceStatusBadge(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Sent => "bg-primary",
        InvoiceStatus.Overdue => "bg-danger",
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Cancelled => "bg-dark",
        InvoiceStatus.Refunded => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
