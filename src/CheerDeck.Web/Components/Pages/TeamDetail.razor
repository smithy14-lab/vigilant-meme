@page "/teams/{Id:guid}"
@rendermode InteractiveServer
@inject TeamService TeamService
@inject AthleteService AthleteService
@inject NavigationManager Nav

<PageTitle>Team Details - CheerDeck</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_team is null)
{
    <div class="alert alert-warning">Team not found.</div>
    <a href="/teams" class="btn btn-outline-secondary">Back to Teams</a>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/teams">Teams</a></li>
            <li class="breadcrumb-item active">@_team.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@_team.Name</h1>
        <span class="badge fs-6 bg-primary">@_team.Level</span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">Team Info</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Level</dt>
                        <dd class="col-sm-7">@_team.Level</dd>
                        <dt class="col-sm-5">Division</dt>
                        <dd class="col-sm-7">@(_team.AgeGridDivision ?? "Not set")</dd>
                        <dt class="col-sm-5">Head Coach</dt>
                        <dd class="col-sm-7">@(_team.HeadCoach?.FullName ?? "Not assigned")</dd>
                        <dt class="col-sm-5">Members</dt>
                        <dd class="col-sm-7">@_team.Members.Count</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Members</span>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => _showAddMember = !_showAddMember">
                        @(_showAddMember ? "Cancel" : "Add Member")
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (_showAddMember)
                    {
                        <div class="p-3 border-bottom">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-5">
                                    <label class="form-label">Athlete</label>
                                    <select class="form-select" @bind="_selectedAthleteId">
                                        <option value="">-- Select --</option>
                                        @foreach (var a in _availableAthletes)
                                        {
                                            <option value="@a.Id">@a.FullName</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Position</label>
                                    <input class="form-control" @bind="_addPosition" />
                                </div>
                                <div class="col-md-2">
                                    <div class="form-check mt-4">
                                        <input class="form-check-input" type="checkbox" @bind="_addIsAlternate" id="altCheck" />
                                        <label class="form-check-label" for="altCheck">Alternate</label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-success w-100" @onclick="AddMember" disabled="@_saving">Add</button>
                                </div>
                            </div>
                        </div>
                    }
                    @if (_team.Members.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">No members yet.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr><th>Athlete</th><th>Position</th><th>Alternate</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var m in _team.Members)
                                {
                                    <tr>
                                        <td><a href="/athletes/@m.AthleteId">@m.Athlete.FullName</a></td>
                                        <td>@(m.Position ?? "-")</td>
                                        <td>@(m.IsAlternate ? "Yes" : "")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveMember(m.AthleteId)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Music</div>
        <div class="card-body">
            @if (_team.Music.Count == 0)
            {
                <p class="text-muted mb-0">No music files uploaded.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr><th>File</th><th>Duration</th><th>Licence</th><th>Current</th><th>Uploaded</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _team.Music)
                        {
                            <tr>
                                <td>@m.FileName</td>
                                <td>@(m.Duration?.ToString(@"m\:ss") ?? "-")</td>
                                <td>
                                    <span class="badge @(m.LicenceVerified ? "bg-success" : "bg-warning text-dark")">
                                        @(m.LicenceVerified ? "Verified" : "Pending")
                                    </span>
                                </td>
                                <td>@(m.IsCurrent ? "Yes" : "")</td>
                                <td>@m.UploadedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            <div class="mt-3 p-3 border rounded bg-light text-muted text-center">
                <span>Music upload area (upload backend not yet implemented)</span>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _showAddMember;
    private bool _saving;
    private Team? _team;
    private List<Athlete> _allAthletes = new();
    private List<Athlete> _availableAthletes = new();
    private string _selectedAthleteId = string.Empty;
    private string? _addPosition;
    private bool _addIsAlternate;

    protected override async Task OnInitializedAsync()
    {
        _allAthletes = await AthleteService.GetAllAsync();
        await LoadTeam();
    }

    private async Task LoadTeam()
    {
        _loading = true;
        _team = await TeamService.GetByIdAsync(Id);
        RefreshAvailableAthletes();
        _loading = false;
    }

    private void RefreshAvailableAthletes()
    {
        if (_team is null) return;
        var memberIds = _team.Members.Select(m => m.AthleteId).ToHashSet();
        _availableAthletes = _allAthletes.Where(a => !memberIds.Contains(a.Id)).ToList();
    }

    private async Task AddMember()
    {
        if (!Guid.TryParse(_selectedAthleteId, out var athleteId)) return;

        _saving = true;
        await TeamService.AddMemberAsync(Id, athleteId, _addPosition, _addIsAlternate);
        _selectedAthleteId = string.Empty;
        _addPosition = null;
        _addIsAlternate = false;
        _showAddMember = false;
        _saving = false;
        await LoadTeam();
    }

    private async Task RemoveMember(Guid athleteId)
    {
        await TeamService.RemoveMemberAsync(Id, athleteId);
        await LoadTeam();
    }
}
