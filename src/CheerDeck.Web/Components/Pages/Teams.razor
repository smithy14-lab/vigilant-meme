@page "/teams"
@rendermode InteractiveServer
@inject TeamService TeamService
@inject CoachService CoachService

<PageTitle>Teams - CheerDeck</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Teams</h1>
    <button class="btn btn-primary" @onclick="() => _showForm = !_showForm">
        @(_showForm ? "Cancel" : "Add Team")
    </button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New Team</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="_newTeam.Name" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Level</label>
                    <select class="form-select" @bind="_newTeam.Level">
                        @foreach (var level in Enum.GetValues<CheerLevel>())
                        {
                            <option value="@level">@level</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Age Division</label>
                    <input class="form-control" @bind="_newTeam.AgeGridDivision" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Head Coach</label>
                    <select class="form-select" @bind="_selectedCoachId">
                        <option value="">-- None --</option>
                        @foreach (var c in _coaches)
                        {
                            <option value="@c.Id">@c.FullName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="CreateTeam" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_teams.Count == 0)
{
    <div class="alert alert-info">No teams found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Level</th>
                <th>Division</th>
                <th>Members</th>
                <th>Head Coach</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in _teams)
            {
                <tr>
                    <td>@t.Name</td>
                    <td>@t.Level</td>
                    <td>@(t.AgeGridDivision ?? "-")</td>
                    <td>@t.Members.Count</td>
                    <td>@(t.HeadCoach?.FullName ?? "-")</td>
                    <td><a href="/teams/@t.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private List<Team> _teams = new();
    private List<Coach> _coaches = new();
    private Team _newTeam = new();
    private string _selectedCoachId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _coaches = await CoachService.GetAllAsync();
        await LoadTeams();
    }

    private async Task LoadTeams()
    {
        _loading = true;
        _teams = await TeamService.GetAllAsync();
        _loading = false;
    }

    private async Task CreateTeam()
    {
        if (string.IsNullOrWhiteSpace(_newTeam.Name))
            return;

        _saving = true;
        if (Guid.TryParse(_selectedCoachId, out var coachId))
            _newTeam.HeadCoachId = coachId;

        await TeamService.CreateAsync(_newTeam);
        _newTeam = new Team();
        _selectedCoachId = string.Empty;
        _showForm = false;
        _saving = false;
        await LoadTeams();
    }
}
