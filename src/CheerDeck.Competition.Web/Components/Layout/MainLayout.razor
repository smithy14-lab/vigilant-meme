@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="text-muted">CheerDeck Competitions</span>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">@(context.User.FindFirst("FullName")?.Value ?? context.User.Identity?.Name)</span>
                        <span class="badge bg-secondary">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        <form method="post" action="/account/perform-logout">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
