@page "/awards"
@attribute [Authorize(Roles = $"{AppRoles.EventProducer},{AppRoles.Tabulator}")]
@rendermode InteractiveServer
@inject EventService EventService
@inject AppDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Awards - CheerDeck Competitions</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Awards</h1>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Select Event</label>
            <select class="form-select" value="@_selectedEventId" @onchange="OnEventSelected">
                <option value="">-- Select Event --</option>
                @if (_events is not null)
                {
                    @foreach (var evt in _events)
                    {
                        <option value="@evt.Id">@evt.Name</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_selectedEvent is not null)
    {
        @foreach (var div in _selectedEvent.Divisions.OrderBy(d => d.SortOrder))
        {
            var divResults = _results.Where(r => r.DivisionId == div.Id && r.IsReleased).OrderBy(r => r.Rank).ToList();
            var divAwards = _awards.Where(a => a.DivisionId == div.Id).ToList();

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@div.Name <span class="badge bg-info text-dark ms-2">@div.Level</span></h5>
                    @if (divResults.Any() && !divAwards.Any())
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => AutoAssignAwards(div, divResults)">
                            Auto-Assign Awards
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (!divResults.Any())
                    {
                        <p class="text-muted mb-0">No released results for this division yet. Release scores from the Scoring page first.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Team</th>
                                    <th class="text-end">Score</th>
                                    <th>Award</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in divResults)
                                {
                                    var award = divAwards.FirstOrDefault(a => a.EntryId == result.EntryId);
                                    <tr>
                                        <td><strong>@result.Rank</strong></td>
                                        <td>@(result.Entry.TeamName ?? result.Entry.Team?.Name ?? "-")</td>
                                        <td class="text-end">@result.FinalScore.ToString("F2")</td>
                                        <td>
                                            @if (award is not null)
                                            {
                                                <span class="badge @AwardBadge(award.Type)">
                                                    @(award.CustomName ?? award.Type.ToString())
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (award is null)
                                            {
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-outline-warning btn-sm" @onclick="() => AssignAward(div, result, AwardType.FirstPlace)">1st</button>
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => AssignAward(div, result, AwardType.SecondPlace)">2nd</button>
                                                    <button class="btn btn-outline-info btn-sm" @onclick="() => AssignAward(div, result, AwardType.ThirdPlace)">3rd</button>
                                                    <button class="btn btn-outline-success btn-sm" @onclick="() => AssignAward(div, result, AwardType.GrandChampion)">GC</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveAward(award)">Remove</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        @if (divAwards.Any())
                        {
                            <div class="mt-3">
                                <button class="btn btn-primary" @onclick="() => AnnounceAwards(divAwards)" disabled="@divAwards.All(a => a.IsAnnounced)">
                                    @(divAwards.All(a => a.IsAnnounced) ? "Awards Announced" : "Mark as Announced")
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        @if (_awards.Any())
        {
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0">Special Awards</h5></div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Award Name</label>
                            <input type="text" class="form-control" @bind="_specialAwardName" placeholder="e.g. Most Entertaining" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Division</label>
                            <select class="form-select" @bind="_specialAwardDivisionId">
                                <option value="">All Divisions</option>
                                @foreach (var div in _selectedEvent.Divisions)
                                {
                                    <option value="@div.Id">@div.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Team</label>
                            <select class="form-select" @bind="_specialAwardEntryId">
                                <option value="">-- Select --</option>
                                @foreach (var entry in _selectedEvent.Entries)
                                {
                                    <option value="@entry.Id">@(entry.TeamName ?? entry.Team?.Name ?? "-")</option>
                                }
                            </select>
                        </div>
                    </div>
                    <button class="btn btn-success" @onclick="AddSpecialAward" disabled="@(string.IsNullOrWhiteSpace(_specialAwardName))">
                        Add Special Award
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Event>? _events;
    private Event? _selectedEvent;
    private Guid _selectedEventId;
    private List<TabulatedResult> _results = new();
    private List<Award> _awards = new();
    private bool _loading;
    private string _specialAwardName = "";
    private string _specialAwardDivisionId = "";
    private string _specialAwardEntryId = "";

    protected override async Task OnInitializedAsync()
    {
        _events = await EventService.GetAllAsync();
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        _results.Clear();
        _awards.Clear();

        if (!Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedEventId = Guid.Empty;
            _selectedEvent = null;
            return;
        }

        _loading = true;
        _selectedEventId = id;
        _selectedEvent = await EventService.GetByIdAsync(id);

        _results = await Db.TabulatedResults
            .Include(r => r.Entry).ThenInclude(e2 => e2.Team)
            .Include(r => r.Division)
            .Where(r => r.Entry.EventId == id)
            .ToListAsync();

        _awards = await Db.Awards
            .Where(a => a.EventId == id)
            .ToListAsync();

        _loading = false;
    }

    private async Task AutoAssignAwards(Division div, List<TabulatedResult> results)
    {
        var topThree = results.Take(3).ToList();
        var types = new[] { AwardType.FirstPlace, AwardType.SecondPlace, AwardType.ThirdPlace };

        for (int i = 0; i < topThree.Count; i++)
        {
            Db.Awards.Add(new Award
            {
                EventId = _selectedEventId,
                DivisionId = div.Id,
                EntryId = topThree[i].EntryId,
                Type = types[i]
            });
        }

        await Db.SaveChangesAsync();
        _awards = await Db.Awards.Where(a => a.EventId == _selectedEventId).ToListAsync();
    }

    private async Task AssignAward(Division div, TabulatedResult result, AwardType type)
    {
        Db.Awards.Add(new Award
        {
            EventId = _selectedEventId,
            DivisionId = div.Id,
            EntryId = result.EntryId,
            Type = type
        });
        await Db.SaveChangesAsync();
        _awards = await Db.Awards.Where(a => a.EventId == _selectedEventId).ToListAsync();
    }

    private async Task RemoveAward(Award award)
    {
        Db.Awards.Remove(award);
        await Db.SaveChangesAsync();
        _awards = await Db.Awards.Where(a => a.EventId == _selectedEventId).ToListAsync();
    }

    private async Task AnnounceAwards(List<Award> awards)
    {
        foreach (var a in awards)
            a.IsAnnounced = true;
        await Db.SaveChangesAsync();
    }

    private async Task AddSpecialAward()
    {
        if (string.IsNullOrWhiteSpace(_specialAwardName) || !Guid.TryParse(_specialAwardEntryId, out var entryId))
            return;

        Guid.TryParse(_specialAwardDivisionId, out var divId);
        if (divId == Guid.Empty && _selectedEvent?.Divisions.Any() == true)
            divId = _selectedEvent.Divisions.First().Id;

        Db.Awards.Add(new Award
        {
            EventId = _selectedEventId,
            DivisionId = divId,
            EntryId = entryId,
            Type = AwardType.SpecialAward,
            CustomName = _specialAwardName.Trim()
        });
        await Db.SaveChangesAsync();

        _awards = await Db.Awards.Where(a => a.EventId == _selectedEventId).ToListAsync();
        _specialAwardName = "";
        _specialAwardEntryId = "";
    }

    private static string AwardBadge(AwardType type) => type switch
    {
        AwardType.FirstPlace => "bg-warning text-dark",
        AwardType.SecondPlace => "bg-secondary",
        AwardType.ThirdPlace => "bg-info text-dark",
        AwardType.GrandChampion => "bg-success",
        AwardType.SpecialAward => "bg-primary",
        _ => "bg-dark"
    };
}
