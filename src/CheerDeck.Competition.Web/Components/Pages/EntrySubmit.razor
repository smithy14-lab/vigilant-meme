@page "/events/{EventId:guid}/enter"
@page "/entries/submit"
@attribute [Authorize]
@rendermode InteractiveServer
@inject EntryService EntryService
@inject EventService EventService
@inject NavigationManager Navigation

<PageTitle>Submit Entry — CheerDeck</PageTitle>

<div class="container" style="max-width: 860px;">

    @* ─── Progress stepper ─── *@
    @if (!submitted)
    {
        <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
            @for (int i = 1; i <= 5; i++)
            {
                var step = i;
                var isActive = step == currentStep;
                var isDone = step < currentStep;
                <div class="text-center flex-fill position-relative">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center @(isActive ? "bg-primary text-white" : isDone ? "bg-success text-white" : "bg-light text-muted border")"
                         style="width:40px;height:40px;font-weight:600;">
                        @if (isDone)
                        {
                            <span>&#10003;</span>
                        }
                        else
                        {
                            @step
                        }
                    </div>
                    <div class="small mt-1 @(isActive ? "fw-semibold text-primary" : "text-muted")">@StepLabel(step)</div>
                </div>
                @if (i < 5)
                {
                    <div class="flex-fill align-self-start" style="border-top:2px solid @(i < currentStep ? "#198754" : "#dee2e6");margin-top:20px;"></div>
                }
            }
        </div>
    }

    @* ─── Loading ─── *@
    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width:3rem;height:3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-3">Loading events...</p>
        </div>
    }

    @* ─── Confirmation ─── *@
    else if (submitted && submittedEntry is not null)
    {
        <div class="card border-success shadow-sm mt-4">
            <div class="card-body text-center py-5">
                <div class="rounded-circle bg-success d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <span class="text-white" style="font-size:2rem;">&#10003;</span>
                </div>
                <h2 class="mb-2">Entry Submitted Successfully</h2>
                <p class="lead text-muted mb-4">Your entry has been received and is pending payment.</p>

                <div class="card bg-light border-0 mx-auto mb-4" style="max-width:480px;">
                    <div class="card-body">
                        <div class="row text-start">
                            <div class="col-5 text-muted mb-2">Entry Number</div>
                            <div class="col-7 fw-bold mb-2"><code class="fs-5">@submittedEntry.EntryNumber</code></div>
                            <div class="col-5 text-muted mb-2">Team</div>
                            <div class="col-7 mb-2">@submittedEntry.TeamName</div>
                            <div class="col-5 text-muted mb-2">Club</div>
                            <div class="col-7 mb-2">@submittedEntry.ClubName</div>
                            <div class="col-5 text-muted mb-2">Division</div>
                            <div class="col-7 mb-2">@(selectedDivision?.Name ?? "-")</div>
                            <div class="col-5 text-muted mb-2">Entry Fee</div>
                            <div class="col-7 mb-2 fw-semibold text-success">@submittedEntry.EntryFee.ToString("C")</div>
                            <div class="col-5 text-muted mb-2">Status</div>
                            <div class="col-7 mb-2"><span class="badge bg-warning text-dark">Payment Pending</span></div>
                        </div>
                    </div>
                </div>

                <p class="text-muted small mb-4">
                    You will receive a payment link at <strong>@submittedEntry.ContactEmail</strong> shortly.
                    Please retain your entry number for reference.
                </p>

                <div class="d-flex justify-content-center gap-3">
                    @if (selectedEvent is not null)
                    {
                        <a href="/events/@selectedEvent.Id" class="btn btn-outline-primary">View Event</a>
                    }
                    <a href="/public-events" class="btn btn-outline-secondary">Browse Events</a>
                    <button class="btn btn-primary" @onclick="StartNewEntry">Submit Another Entry</button>
                </div>
            </div>
        </div>
    }

    @* ─── Wizard Steps ─── *@
    else
    {
        @if (errorMessage is not null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Error:</strong> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @* ─── STEP 1: Select Event ─── *@
        @if (currentStep == 1)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0">Select Competition</h4>
                    <small class="text-muted">Choose an event with open entries</small>
                </div>
                <div class="card-body">
                    @if (openEvents is null)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm" role="status"></div>
                            <span class="text-muted ms-2">Loading events...</span>
                        </div>
                    }
                    else if (!openEvents.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted mb-0">No events are currently accepting entries.</p>
                            <a href="/public-events" class="btn btn-outline-primary mt-3">View All Events</a>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var evt in openEvents)
                            {
                                var daysRemaining = evt.EntryDeadline.DayNumber - DateOnly.FromDateTime(DateTime.UtcNow).DayNumber;
                                var isSelected = selectedEventId == evt.Id;
                                <div class="col-12">
                                    <div class="card @(isSelected ? "border-primary border-2 bg-primary bg-opacity-10" : "border") cursor-pointer"
                                         @onclick="() => SelectEvent(evt)" role="button" style="cursor:pointer;">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h5 class="card-title mb-1">
                                                        @if (isSelected)
                                                        {
                                                            <span class="text-primary me-1">&#10003;</span>
                                                        }
                                                        @evt.Name
                                                    </h5>
                                                    @if (!string.IsNullOrEmpty(evt.VenueName))
                                                    {
                                                        <p class="text-muted mb-1 small">@evt.VenueName</p>
                                                    }
                                                    <div class="d-flex flex-wrap gap-3 mt-2">
                                                        <span class="text-muted small">
                                                            <strong>Deadline:</strong> @evt.EntryDeadline.ToString("d MMM yyyy")
                                                        </span>
                                                        <span class="text-muted small">
                                                            <strong>Base Fee:</strong> @evt.BaseEntryFee.ToString("C")
                                                        </span>
                                                        <span class="text-muted small">
                                                            <strong>Divisions:</strong> @evt.Divisions.Count
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="text-end">
                                                    @if (daysRemaining <= 7)
                                                    {
                                                        <span class="badge bg-danger">@daysRemaining day@(daysRemaining == 1 ? "" : "s") left</span>
                                                    }
                                                    else if (daysRemaining <= 14)
                                                    {
                                                        <span class="badge bg-warning text-dark">@daysRemaining days left</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success">@daysRemaining days left</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer bg-white d-flex justify-content-end py-3">
                    <button class="btn btn-primary px-4"
                            disabled="@(selectedEventId == Guid.Empty)"
                            @onclick="() => GoToStep(2)">
                        Continue
                        <span class="ms-1">&rarr;</span>
                    </button>
                </div>
            </div>
        }

        @* ─── STEP 2: Select Division ─── *@
        @if (currentStep == 2)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0">Select Division</h4>
                    <small class="text-muted">@selectedEvent?.Name</small>
                </div>
                <div class="card-body">
                    @if (selectedEvent?.Divisions.Any() != true)
                    {
                        <p class="text-muted mb-0">No divisions are available for this event.</p>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var div in selectedEvent.Divisions.OrderBy(d => d.SortOrder))
                            {
                                var fee = div.EntryFeeOverride ?? selectedEvent.BaseEntryFee;
                                var isSelected = selectedDivisionId == div.Id;
                                <div class="col-md-6">
                                    <div class="card h-100 @(isSelected ? "border-primary border-2 bg-primary bg-opacity-10" : "border")"
                                         @onclick="() => SelectDivision(div)" role="button" style="cursor:pointer;">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="card-title mb-0">
                                                    @if (isSelected)
                                                    {
                                                        <span class="text-primary me-1">&#10003;</span>
                                                    }
                                                    @div.Name
                                                </h5>
                                                <span class="badge bg-info text-dark">@div.Level</span>
                                            </div>
                                            <div class="d-flex flex-column gap-1">
                                                <span class="small">
                                                    <strong>Fee:</strong>
                                                    <span class="text-success fw-semibold">@fee.ToString("C")</span>
                                                </span>
                                                <span class="small text-muted">
                                                    <strong>Scoresheet:</strong> @div.ScoresheetType
                                                </span>
                                                @if (div.MinTeamSize.HasValue || div.MaxTeamSize.HasValue)
                                                {
                                                    <span class="small text-muted">
                                                        <strong>Team Size:</strong> @(div.MinTeamSize?.ToString() ?? "No min") &ndash; @(div.MaxTeamSize?.ToString() ?? "No max")
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer bg-white d-flex justify-content-between py-3">
                    <button class="btn btn-outline-secondary px-4" @onclick="() => GoToStep(1)">
                        <span class="me-1">&larr;</span> Back
                    </button>
                    <button class="btn btn-primary px-4"
                            disabled="@(selectedDivisionId == Guid.Empty)"
                            @onclick="() => GoToStep(3)">
                        Continue <span class="ms-1">&rarr;</span>
                    </button>
                </div>
            </div>
        }

        @* ─── STEP 3: Team Details ─── *@
        @if (currentStep == 3)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0">Team Details</h4>
                    <small class="text-muted">@selectedEvent?.Name &mdash; @selectedDivision?.Name</small>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Team Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control @(teamNameError is not null ? "is-invalid" : "")"
                                   @bind="teamName" @bind:event="oninput" placeholder="e.g. Lightning All Stars" />
                            @if (teamNameError is not null)
                            {
                                <div class="invalid-feedback">@teamNameError</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Club / Organisation Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control @(clubNameError is not null ? "is-invalid" : "")"
                                   @bind="clubName" @bind:event="oninput" placeholder="e.g. Phoenix Cheer Academy" />
                            @if (clubNameError is not null)
                            {
                                <div class="invalid-feedback">@clubNameError</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Estimated Team Size <span class="text-danger">*</span></label>
                            <input type="number" class="form-control @(teamSizeError is not null ? "is-invalid" : "")"
                                   @bind="estimatedTeamSize" min="1" max="50" />
                            @if (teamSizeError is not null)
                            {
                                <div class="invalid-feedback">@teamSizeError</div>
                            }
                            @if (selectedDivision is not null && (selectedDivision.MinTeamSize.HasValue || selectedDivision.MaxTeamSize.HasValue))
                            {
                                <div class="form-text">
                                    This division requires @(selectedDivision.MinTeamSize?.ToString() ?? "1") to @(selectedDivision.MaxTeamSize?.ToString() ?? "unlimited") athletes.
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Contact Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control @(contactEmailError is not null ? "is-invalid" : "")"
                                   @bind="contactEmail" @bind:event="oninput" placeholder="coach@example.com" />
                            @if (contactEmailError is not null)
                            {
                                <div class="invalid-feedback">@contactEmailError</div>
                            }
                            <div class="form-text">Payment confirmation and updates will be sent here.</div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-between py-3">
                    <button class="btn btn-outline-secondary px-4" @onclick="() => GoToStep(2)">
                        <span class="me-1">&larr;</span> Back
                    </button>
                    <button class="btn btn-primary px-4" @onclick="ValidateAndGoToStep4">
                        Continue <span class="ms-1">&rarr;</span>
                    </button>
                </div>
            </div>
        }

        @* ─── STEP 4: Music Metadata ─── *@
        @if (currentStep == 4)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0">Music Details <span class="badge bg-secondary ms-2 small">Optional</span></h4>
                    <small class="text-muted">Upload your routine music file and provide duration details.</small>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Music File</label>
                            <InputFile OnChange="OnMusicFileSelected" accept=".mp3,.wav,.m4a,.aac" class="form-control" />
                            <div class="form-text">MP3, WAV, AAC, or M4A — max 50 MB.</div>
                            @if (!string.IsNullOrEmpty(musicFileName))
                            {
                                <div class="mt-2 text-success small">
                                    Selected: @musicFileName (@FormatFileSize(musicFileSize))
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(musicUploadError))
                            {
                                <div class="mt-2 text-danger small">@musicUploadError</div>
                            }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Duration</label>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="number" class="form-control" @bind="musicMinutes" min="0" max="9" placeholder="Min" style="width:80px;" />
                                <span class="fw-bold">:</span>
                                <input type="number" class="form-control" @bind="musicSeconds" min="0" max="59" placeholder="Sec" style="width:80px;" />
                            </div>
                            <div class="form-text">Minutes : Seconds</div>
                        </div>
                    </div>

                    <div class="alert alert-info mt-4 mb-0 d-flex align-items-center">
                        <span class="me-2" style="font-size:1.2rem;">&#9432;</span>
                        <div>
                            Music will be uploaded when you submit your entry.
                            Music licence verification will happen after upload.
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-between py-3">
                    <button class="btn btn-outline-secondary px-4" @onclick="() => GoToStep(3)">
                        <span class="me-1">&larr;</span> Back
                    </button>
                    <button class="btn btn-primary px-4" @onclick="() => GoToStep(5)">
                        Continue <span class="ms-1">&rarr;</span>
                    </button>
                </div>
            </div>
        }

        @* ─── STEP 5: Review & Pay ─── *@
        @if (currentStep == 5)
        {
            var entryFee = selectedDivision?.EntryFeeOverride ?? selectedEvent?.BaseEntryFee ?? 0m;
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0">Review &amp; Submit</h4>
                    <small class="text-muted">Please review your entry details before submitting.</small>
                </div>
                <div class="card-body">
                    @* Event & Division *@
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0 text-muted text-uppercase small">Competition</h6>
                            <button class="btn btn-link btn-sm p-0" @onclick="() => GoToStep(1)">Edit</button>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-1"><strong>Event:</strong> @selectedEvent?.Name</div>
                                @if (!string.IsNullOrEmpty(selectedEvent?.VenueName))
                                {
                                    <div class="small text-muted">@selectedEvent.VenueName</div>
                                }
                            </div>
                            <div class="col-md-6">
                                <div class="mb-1"><strong>Division:</strong> @selectedDivision?.Name</div>
                                <div class="small text-muted">Level: @selectedDivision?.Level</div>
                            </div>
                        </div>
                    </div>

                    @* Team Details *@
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0 text-muted text-uppercase small">Team Details</h6>
                            <button class="btn btn-link btn-sm p-0" @onclick="() => GoToStep(3)">Edit</button>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-1"><strong>Team:</strong> @teamName</div>
                                <div class="mb-1"><strong>Club:</strong> @clubName</div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-1"><strong>Est. Size:</strong> @estimatedTeamSize athletes</div>
                                <div class="mb-1"><strong>Contact:</strong> @contactEmail</div>
                            </div>
                        </div>
                    </div>

                    @* Music *@
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0 text-muted text-uppercase small">Music</h6>
                            <button class="btn btn-link btn-sm p-0" @onclick="() => GoToStep(4)">Edit</button>
                        </div>
                        @if (!string.IsNullOrEmpty(musicFileName))
                        {
                            <div><strong>File:</strong> @musicFileName</div>
                            @if (musicMinutes > 0 || musicSeconds > 0)
                            {
                                <div><strong>Duration:</strong> @musicMinutes:@musicSeconds.ToString("D2")</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No music details provided yet.</span>
                        }
                    </div>

                    @* Fee Summary *@
                    <div class="card bg-light border-0 mt-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-0">Entry Fee</h5>
                                    <small class="text-muted">
                                        @(selectedDivision?.EntryFeeOverride.HasValue == true ? "Division-specific fee" : "Standard event fee")
                                    </small>
                                </div>
                                <h3 class="mb-0 text-success fw-bold">@entryFee.ToString("C")</h3>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning mt-3 mb-0 d-flex align-items-center">
                        <span class="me-2" style="font-size:1.2rem;">&#9888;</span>
                        <div>
                            By submitting this entry you agree to the competition terms and conditions.
                            Payment is required to confirm your entry.
                            Entries without payment by <strong>@selectedEvent?.EntryDeadline.ToString("d MMM yyyy")</strong> may be withdrawn.
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-between py-3">
                    <button class="btn btn-outline-secondary px-4" @onclick="() => GoToStep(4)">
                        <span class="me-1">&larr;</span> Back
                    </button>
                    <button class="btn btn-success btn-lg px-5" @onclick="SubmitEntry" disabled="@submitting">
                        @if (submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <span>Submit Entry &amp; Proceed to Payment</span>
                        }
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid EventId { get; set; }

    [SupplyParameterFromQuery(Name = "eventId")]
    public Guid? QueryEventId { get; set; }

    // State
    private bool loading = true;
    private int currentStep = 1;
    private string? errorMessage;
    private bool submitting;
    private bool submitted;
    private EventEntry? submittedEntry;

    // Step 1 — Event selection
    private List<Event>? openEvents;
    private Guid selectedEventId;
    private Event? selectedEvent;

    // Step 2 — Division selection
    private Guid selectedDivisionId;
    private Division? selectedDivision;

    // Step 3 — Team details
    private string teamName = string.Empty;
    private string clubName = string.Empty;
    private int estimatedTeamSize = 5;
    private string contactEmail = string.Empty;
    private string? teamNameError;
    private string? clubNameError;
    private string? teamSizeError;
    private string? contactEmailError;

    // Step 4 — Music
    private string musicFileName = string.Empty;
    private int musicMinutes;
    private int musicSeconds;
    private IBrowserFile? musicFile;
    private long musicFileSize;
    private string? musicUploadError;

    protected override async Task OnInitializedAsync()
    {
        openEvents = await EventService.GetOpenEventsAsync();

        // If event was supplied via route parameter or query string, pre-select it
        var preselectedId = EventId != Guid.Empty ? EventId : QueryEventId ?? Guid.Empty;
        if (preselectedId != Guid.Empty)
        {
            var match = openEvents.FirstOrDefault(e => e.Id == preselectedId);
            if (match is not null)
            {
                SelectEvent(match);
                currentStep = 2; // skip straight to division selection
            }
        }

        loading = false;
    }

    // ─── Navigation ───
    private void GoToStep(int step)
    {
        currentStep = step;
    }

    // ─── Step 1 helpers ───
    private void SelectEvent(Event evt)
    {
        selectedEventId = evt.Id;
        selectedEvent = evt;
        // Reset downstream selections when event changes
        selectedDivisionId = Guid.Empty;
        selectedDivision = null;
    }

    // ─── Step 2 helpers ───
    private void SelectDivision(Division div)
    {
        selectedDivisionId = div.Id;
        selectedDivision = div;
    }

    // ─── Step 3 validation ───
    private void ValidateAndGoToStep4()
    {
        teamNameError = string.IsNullOrWhiteSpace(teamName) ? "Team name is required." : null;
        clubNameError = string.IsNullOrWhiteSpace(clubName) ? "Club name is required." : null;
        contactEmailError = string.IsNullOrWhiteSpace(contactEmail) || !contactEmail.Contains('@')
            ? "A valid email address is required." : null;

        // Validate team size against division limits
        teamSizeError = null;
        if (estimatedTeamSize < 1)
        {
            teamSizeError = "Team size must be at least 1.";
        }
        else if (selectedDivision is not null)
        {
            if (selectedDivision.MinTeamSize.HasValue && estimatedTeamSize < selectedDivision.MinTeamSize.Value)
                teamSizeError = $"Minimum team size for this division is {selectedDivision.MinTeamSize.Value}.";
            else if (selectedDivision.MaxTeamSize.HasValue && estimatedTeamSize > selectedDivision.MaxTeamSize.Value)
                teamSizeError = $"Maximum team size for this division is {selectedDivision.MaxTeamSize.Value}.";
        }

        if (teamNameError is null && clubNameError is null && teamSizeError is null && contactEmailError is null)
        {
            GoToStep(4);
        }
    }

    // ─── Submit ───
    private async Task SubmitEntry()
    {
        if (selectedEventId == Guid.Empty || selectedDivisionId == Guid.Empty) return;

        // Final deadline check
        if (selectedEvent is not null && selectedEvent.EntryDeadline < DateOnly.FromDateTime(DateTime.UtcNow))
        {
            errorMessage = "The entry deadline for this event has passed.";
            return;
        }

        submitting = true;
        errorMessage = null;

        try
        {
            var entry = new EventEntry
            {
                EventId = selectedEventId,
                DivisionId = selectedDivisionId,
                ClubTenantId = Guid.Empty, // will be set from tenant context in service
                TeamName = teamName.Trim(),
                ClubName = clubName.Trim(),
                ContactEmail = contactEmail.Trim(),
                EstimatedTeamSize = estimatedTeamSize,
                MusicFileName = string.IsNullOrWhiteSpace(musicFileName) ? null : musicFileName.Trim(),
                MusicDuration = (musicMinutes > 0 || musicSeconds > 0)
                    ? new TimeSpan(0, musicMinutes, musicSeconds)
                    : null
            };

            submittedEntry = await EntryService.CreateAsync(entry);
            submitted = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit entry: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }

    private void StartNewEntry()
    {
        submitted = false;
        submittedEntry = null;
        currentStep = 1;
        selectedEventId = Guid.Empty;
        selectedEvent = null;
        selectedDivisionId = Guid.Empty;
        selectedDivision = null;
        teamName = string.Empty;
        clubName = string.Empty;
        estimatedTeamSize = 5;
        contactEmail = string.Empty;
        musicFileName = string.Empty;
        musicMinutes = 0;
        musicSeconds = 0;
        errorMessage = null;
    }

    private void OnMusicFileSelected(InputFileChangeEventArgs e)
    {
        musicUploadError = null;
        var file = e.File;

        if (file.Size > 50_000_000)
        {
            musicUploadError = "File must be under 50 MB.";
            return;
        }

        var allowedExtensions = new[] { ".mp3", ".wav", ".m4a", ".aac" };
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!allowedExtensions.Contains(ext))
        {
            musicUploadError = "Only MP3, WAV, AAC, and M4A files are allowed.";
            return;
        }

        musicFile = file;
        musicFileName = file.Name;
        musicFileSize = file.Size;
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

    private static string StepLabel(int step) => step switch
    {
        1 => "Event",
        2 => "Division",
        3 => "Team",
        4 => "Music",
        5 => "Review",
        _ => ""
    };
}
