@page "/results"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ScoringService ScoringService
@inject EventService EventService

<PageTitle>Results</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Results</h1>

    @if (events is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label">Event</label>
                <select class="form-select" value="@selectedEventId" @onchange="OnEventSelected">
                    <option value="">-- Select Event --</option>
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.Name</option>
                    }
                </select>
            </div>
            @if (selectedEvent is not null)
            {
                <div class="col-md-4">
                    <label class="form-label">Division</label>
                    <select class="form-select" value="@selectedDivisionId" @onchange="OnDivisionSelected">
                        <option value="">-- Select Division --</option>
                        @foreach (var div in selectedEvent.Divisions.OrderBy(d => d.SortOrder))
                        {
                            <option value="@div.Id">@div.Name (@div.Level)</option>
                        }
                    </select>
                </div>
            }
        </div>

        @if (loading)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span class="ms-2">Loading results...</span>
            </div>
        }
        else if (selectedDivisionId != Guid.Empty)
        {
            @if (actionMessage is not null)
            {
                <div class="alert @(actionSuccess ? "alert-success" : "alert-danger") alert-dismissible mb-3">
                    @actionMessage
                    <button type="button" class="btn-close" @onclick="() => actionMessage = null"></button>
                </div>
            }

            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-primary" @onclick="TabulateAll" disabled="@processing">
                    @if (processing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Tabulate All
                </button>
                <button class="btn btn-warning" @onclick="RankDivision" disabled="@processing">
                    Rank Division
                </button>
                <button class="btn btn-success" @onclick="ReleaseScores" disabled="@processing">
                    Release Scores
                </button>
            </div>

            @if (results is null || !results.Any())
            {
                <div class="alert alert-info">No tabulated results yet for this division. Use "Tabulate All" to calculate scores.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th style="width:60px">Rank</th>
                                <th>Team</th>
                                <th class="text-end">Raw Score</th>
                                <th class="text-end">Deductions</th>
                                <th class="text-end">Final Score</th>
                                <th>Status</th>
                                <th>Calculated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in results)
                            {
                                <tr class="@(r.Rank == 1 ? "table-warning" : "")">
                                    <td>
                                        @if (r.Rank > 0)
                                        {
                                            <strong>@r.Rank</strong>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@r.Entry.Team.Name</td>
                                    <td class="text-end">@r.RawScore.ToString("F2")</td>
                                    <td class="text-end text-danger">@(r.DeductionTotal > 0 ? $"-{r.DeductionTotal:F2}" : "-")</td>
                                    <td class="text-end"><strong>@r.FinalScore.ToString("F2")</strong></td>
                                    <td>
                                        @if (r.IsReleased)
                                        {
                                            <span class="badge bg-success">Released</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pending</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@r.CalculatedAt.ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
</div>

@code {
    private List<Event>? events;
    private Event? selectedEvent;
    private Guid selectedEventId;
    private Guid selectedDivisionId;
    private List<TabulatedResult>? results;
    private bool loading;
    private bool processing;
    private string? actionMessage;
    private bool actionSuccess;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetAllAsync();
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        results = null;
        selectedDivisionId = Guid.Empty;
        actionMessage = null;

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedEventId = id;
            selectedEvent = await EventService.GetByIdAsync(id);
        }
        else
        {
            selectedEventId = Guid.Empty;
            selectedEvent = null;
        }
    }

    private async Task OnDivisionSelected(ChangeEventArgs e)
    {
        actionMessage = null;

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedDivisionId = id;
            await LoadResults();
        }
        else
        {
            selectedDivisionId = Guid.Empty;
            results = null;
        }
    }

    private async Task LoadResults()
    {
        loading = true;
        results = await ScoringService.GetResultsAsync(selectedDivisionId);
        loading = false;
    }

    private async Task TabulateAll()
    {
        if (selectedEvent is null || selectedDivisionId == Guid.Empty) return;

        processing = true;
        actionMessage = null;

        try
        {
            var divisionEntries = selectedEvent.Entries
                .Where(en => en.DivisionId == selectedDivisionId)
                .ToList();

            foreach (var entry in divisionEntries)
            {
                await ScoringService.TabulateAsync(entry.Id, selectedDivisionId);
            }

            await LoadResults();
            actionSuccess = true;
            actionMessage = $"Tabulated {divisionEntries.Count} entries.";
        }
        catch (Exception ex)
        {
            actionSuccess = false;
            actionMessage = $"Tabulation error: {ex.Message}";
        }
        finally
        {
            processing = false;
        }
    }

    private async Task RankDivision()
    {
        if (selectedDivisionId == Guid.Empty) return;

        processing = true;
        actionMessage = null;

        try
        {
            await ScoringService.RankDivisionAsync(selectedDivisionId);
            await LoadResults();
            actionSuccess = true;
            actionMessage = "Division ranked successfully.";
        }
        catch (Exception ex)
        {
            actionSuccess = false;
            actionMessage = $"Ranking error: {ex.Message}";
        }
        finally
        {
            processing = false;
        }
    }

    private async Task ReleaseScores()
    {
        if (selectedDivisionId == Guid.Empty) return;

        processing = true;
        actionMessage = null;

        try
        {
            await ScoringService.ReleaseScoresAsync(selectedDivisionId);
            await LoadResults();
            actionSuccess = true;
            actionMessage = "Scores released to public leaderboard.";
        }
        catch (Exception ex)
        {
            actionSuccess = false;
            actionMessage = $"Release error: {ex.Message}";
        }
        finally
        {
            processing = false;
        }
    }
}
