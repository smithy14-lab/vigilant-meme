@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject EventService EventService
@inject EntryService EntryService

<PageTitle>CheerDeck Competitions</PageTitle>

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="display-5 fw-bold">Competition Dashboard</h1>
        <p class="lead text-muted">Manage events, entries, scoring, and results.</p>
    </div>

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body text-center">
                        <h2 class="display-6 fw-bold text-primary">@eventCount</h2>
                        <p class="card-text text-muted mb-0">Total Events</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success h-100">
                    <div class="card-body text-center">
                        <h2 class="display-6 fw-bold text-success">@entryCount</h2>
                        <p class="card-text text-muted mb-0">Total Entries</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info h-100">
                    <div class="card-body text-center">
                        <h2 class="display-6 fw-bold text-info">@upcomingEvents.Count</h2>
                        <p class="card-text text-muted mb-0">Upcoming Events</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body text-center">
                        <h2 class="display-6 fw-bold text-warning">@recentEntries.Count</h2>
                        <p class="card-text text-muted mb-0">Recent Entries</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Upcoming Events</h5>
                <a href="/events" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                @if (!upcomingEvents.Any())
                {
                    <p class="text-muted mb-0">No upcoming events. <a href="/events">Create one</a> to get started.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Venue</th>
                                    <th>Status</th>
                                    <th>Entry Deadline</th>
                                    <th>Entries</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var evt in upcomingEvents)
                                {
                                    <tr>
                                        <td><strong>@evt.Name</strong></td>
                                        <td>@(evt.VenueName ?? "TBD")</td>
                                        <td><span class="badge @StatusBadgeClass(evt.Status)">@evt.Status</span></td>
                                        <td>@evt.EntryDeadline.ToString("d MMM yyyy")</td>
                                        <td>@evt.Entries.Count</td>
                                        <td>
                                            <a href="/events/@evt.Id" class="btn btn-sm btn-outline-primary">View</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Recent Entries -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Recent Entries</h5>
            </div>
            <div class="card-body">
                @if (!recentEntries.Any())
                {
                    <p class="text-muted mb-0">No entries submitted yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Team</th>
                                    <th>Division</th>
                                    <th>Status</th>
                                    <th>Submitted</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in recentEntries)
                                {
                                    <tr>
                                        <td>@entry.Team?.Name</td>
                                        <td>@entry.Division.Name</td>
                                        <td><span class="badge @EntryStatusBadge(entry.Status)">@entry.Status</span></td>
                                        <td>@entry.SubmittedAt.ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool loading = true;
    private int eventCount;
    private int entryCount;
    private List<Event> upcomingEvents = new();
    private List<EventEntry> recentEntries = new();

    protected override async Task OnInitializedAsync()
    {
        var events = await EventService.GetAllAsync();
        eventCount = events.Count;

        upcomingEvents = events
            .Where(e => e.Status != EventStatus.Completed && e.Status != EventStatus.Cancelled)
            .OrderBy(e => e.EntryDeadline)
            .Take(5)
            .ToList();

        var allEntries = new List<EventEntry>();
        foreach (var evt in events)
        {
            var entries = await EntryService.GetEntriesForEventAsync(evt.Id);
            allEntries.AddRange(entries);
        }

        entryCount = allEntries.Count;
        recentEntries = allEntries
            .OrderByDescending(e => e.SubmittedAt)
            .Take(10)
            .ToList();

        loading = false;
    }

    private static string StatusBadgeClass(EventStatus status) => status switch
    {
        EventStatus.Draft => "bg-secondary",
        EventStatus.Published => "bg-info text-dark",
        EventStatus.EntriesOpen => "bg-success",
        EventStatus.EntriesClosed => "bg-warning text-dark",
        EventStatus.InProgress => "bg-primary",
        EventStatus.Completed => "bg-dark",
        EventStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };

    private static string EntryStatusBadge(EntryStatus status) => status switch
    {
        EntryStatus.Pending => "bg-secondary",
        EntryStatus.EligibilityChecked => "bg-info text-dark",
        EntryStatus.PaymentPending => "bg-warning text-dark",
        EntryStatus.Confirmed => "bg-success",
        EntryStatus.Withdrawn => "bg-dark",
        EntryStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };
}
