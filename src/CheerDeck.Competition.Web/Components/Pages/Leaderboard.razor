@page "/leaderboard"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject ScoringService ScoringService
@inject EventService EventService

<PageTitle>Leaderboard</PageTitle>

<div class="container-fluid">
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold">Leaderboard</h1>
    </div>

    @if (events is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4 justify-content-center">
            <div class="col-md-4">
                <select class="form-select form-select-lg" value="@selectedEventId" @onchange="OnEventSelected">
                    <option value="">-- Select Event --</option>
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.Name</option>
                    }
                </select>
            </div>
            @if (selectedEvent is not null)
            {
                <div class="col-md-4">
                    <select class="form-select form-select-lg" value="@selectedDivisionId" @onchange="OnDivisionSelected">
                        <option value="">-- All Divisions --</option>
                        @foreach (var div in selectedEvent.Divisions.OrderBy(d => d.SortOrder))
                        {
                            <option value="@div.Id">@div.Name</option>
                        }
                    </select>
                </div>
            }
        </div>

        @if (loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border spinner-border-lg" role="status"></div>
            </div>
        }
        else if (selectedEvent is not null && selectedDivisionId != Guid.Empty)
        {
            @if (results is null || !results.Any())
            {
                <div class="text-center py-5">
                    <h3 class="text-muted">No released results yet</h3>
                    <p class="text-muted">Results will appear here once scores are released.</p>
                </div>
            }
            else
            {
                var divisionName = selectedEvent.Divisions.FirstOrDefault(d => d.Id == selectedDivisionId)?.Name;
                <h2 class="text-center mb-4">@divisionName</h2>

                @foreach (var r in results)
                {
                    <div class="card mb-3 @RankCardClass(r.Rank)">
                        <div class="card-body py-4">
                            <div class="row align-items-center">
                                <div class="col-2 col-md-1 text-center">
                                    <span class="display-4 fw-bold @RankTextClass(r.Rank)">@r.Rank</span>
                                </div>
                                <div class="col-6 col-md-7">
                                    <h3 class="mb-0 display-6">@r.Entry.Team?.Name</h3>
                                </div>
                                <div class="col-4 col-md-4 text-end">
                                    <span class="display-5 fw-bold">@r.FinalScore.ToString("F2")</span>
                                    @if (r.DeductionTotal > 0)
                                    {
                                        <br />
                                        <small class="text-muted">
                                            Raw: @r.RawScore.ToString("F2") | Ded: -@r.DeductionTotal.ToString("F2")
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        }
        else if (selectedEvent is not null && selectedDivisionId == Guid.Empty)
        {
            <div class="text-center py-5">
                <h3 class="text-muted">Select a division to view results</h3>
            </div>
        }
    }
</div>

@code {
    private List<Event>? events;
    private Event? selectedEvent;
    private Guid selectedEventId;
    private Guid selectedDivisionId;
    private List<TabulatedResult>? results;
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetAllAsync();
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        results = null;
        selectedDivisionId = Guid.Empty;

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedEventId = id;
            selectedEvent = await EventService.GetByIdAsync(id);
        }
        else
        {
            selectedEventId = Guid.Empty;
            selectedEvent = null;
        }
    }

    private async Task OnDivisionSelected(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedDivisionId = id;
            loading = true;
            results = await ScoringService.GetResultsAsync(id, releasedOnly: true);
            loading = false;
        }
        else
        {
            selectedDivisionId = Guid.Empty;
            results = null;
        }
    }

    private static string RankCardClass(int rank) => rank switch
    {
        1 => "border-warning border-3",
        2 => "border-secondary border-2",
        3 => "border-info border-2",
        _ => ""
    };

    private static string RankTextClass(int rank) => rank switch
    {
        1 => "text-warning",
        2 => "text-secondary",
        3 => "text-info",
        _ => "text-muted"
    };
}
