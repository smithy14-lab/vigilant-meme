@page "/running-order"
@attribute [Authorize]
@rendermode InteractiveServer
@inject RunningOrderService RunningOrderService
@inject EventService EventService

<PageTitle>Running Order</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Running Order</h1>

    @if (events is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label">Event</label>
                <select class="form-select" value="@selectedEventId" @onchange="OnEventSelected">
                    <option value="">-- Select Event --</option>
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.Name</option>
                    }
                </select>
            </div>
            @if (selectedEvent is not null)
            {
                <div class="col-md-4">
                    <label class="form-label">Block</label>
                    <select class="form-select" value="@selectedBlockId" @onchange="OnBlockSelected">
                        <option value="">-- Select Block --</option>
                        @foreach (var session in selectedEvent.Sessions.OrderBy(s => s.SortOrder))
                        {
                            @foreach (var block in session.Blocks.OrderBy(b => b.SortOrder))
                            {
                                <option value="@block.Id">@session.Name - @block.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-success" @onclick="AutoSchedule" disabled="@_scheduling">
                        @if (_scheduling) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Auto-Schedule All Entries
                    </button>
                </div>
            }
        </div>

        @if (_scheduleResult is not null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @_scheduleResult
                <button type="button" class="btn-close" @onclick="() => _scheduleResult = null"></button>
            </div>
        }

        @if (loading)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span class="ms-2">Loading running order...</span>
            </div>
        }
        else if (selectedBlockId != Guid.Empty && runningOrder is not null)
        {
            @if (!runningOrder.Any())
            {
                <div class="alert alert-info">No entries in the running order for this block.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:60px">#</th>
                                <th>Team</th>
                                <th>Division</th>
                                <th>Scheduled</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var roe in runningOrder)
                            {
                                <tr class="@RowClass(roe.Status)">
                                    <td><strong>@roe.Position</strong></td>
                                    <td>@roe.Entry.Team?.Name</td>
                                    <td>@roe.Entry.Division.Name</td>
                                    <td>@(roe.ScheduledTime?.ToString("HH:mm") ?? "-")</td>
                                    <td>
                                        <span class="badge @PerformanceStatusBadge(roe.Status)">@roe.Status</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            @if (roe.Status == PerformanceStatus.Scheduled)
                                            {
                                                <button class="btn btn-outline-info" @onclick="() => UpdateStatus(roe.Id, PerformanceStatus.InWarmUp)">
                                                    Warm Up
                                                </button>
                                            }
                                            @if (roe.Status == PerformanceStatus.InWarmUp)
                                            {
                                                <button class="btn btn-outline-warning" @onclick="() => UpdateStatus(roe.Id, PerformanceStatus.OnDeck)">
                                                    On Deck
                                                </button>
                                            }
                                            @if (roe.Status == PerformanceStatus.OnDeck)
                                            {
                                                <button class="btn btn-outline-primary" @onclick="() => UpdateStatus(roe.Id, PerformanceStatus.OnFloor)">
                                                    On Floor
                                                </button>
                                            }
                                            @if (roe.Status == PerformanceStatus.OnFloor)
                                            {
                                                <button class="btn btn-primary" @onclick="() => UpdateStatus(roe.Id, PerformanceStatus.Performing)">
                                                    Performing
                                                </button>
                                            }
                                            @if (roe.Status == PerformanceStatus.Performing)
                                            {
                                                <button class="btn btn-success" @onclick="() => UpdateStatus(roe.Id, PerformanceStatus.Completed)">
                                                    Complete
                                                </button>
                                            }
                                            @if (roe.Status != PerformanceStatus.Completed && roe.Status != PerformanceStatus.Scratched)
                                            {
                                                <button class="btn btn-outline-danger" @onclick="() => UpdateStatus(roe.Id, PerformanceStatus.Scratched)">
                                                    Scratch
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
</div>

@code {
    private List<Event>? events;
    private Event? selectedEvent;
    private Guid selectedEventId;
    private Guid selectedBlockId;
    private List<RunningOrderEntry>? runningOrder;
    private bool loading;
    private bool _scheduling;
    private string? _scheduleResult;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetAllAsync();
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        runningOrder = null;
        selectedBlockId = Guid.Empty;
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedEventId = id;
            selectedEvent = await EventService.GetByIdAsync(id);
        }
        else
        {
            selectedEventId = Guid.Empty;
            selectedEvent = null;
        }
    }

    private async Task OnBlockSelected(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedBlockId = id;
            loading = true;
            runningOrder = await RunningOrderService.GetForBlockAsync(id);
            loading = false;
        }
        else
        {
            selectedBlockId = Guid.Empty;
            runningOrder = null;
        }
    }

    private async Task UpdateStatus(Guid runningOrderEntryId, PerformanceStatus status)
    {
        await RunningOrderService.UpdateStatusAsync(runningOrderEntryId, status);
        runningOrder = await RunningOrderService.GetForBlockAsync(selectedBlockId);
    }

    private static string PerformanceStatusBadge(PerformanceStatus status) => status switch
    {
        PerformanceStatus.Scheduled => "bg-secondary",
        PerformanceStatus.InWarmUp => "bg-info text-dark",
        PerformanceStatus.OnDeck => "bg-warning text-dark",
        PerformanceStatus.OnFloor => "bg-primary",
        PerformanceStatus.Performing => "bg-danger",
        PerformanceStatus.Completed => "bg-success",
        PerformanceStatus.Scratched => "bg-dark",
        _ => "bg-secondary"
    };

    private async Task AutoSchedule()
    {
        if (selectedEventId == Guid.Empty) return;
        _scheduling = true;
        _scheduleResult = null;
        var result = await RunningOrderService.AutoScheduleAsync(selectedEventId);
        _scheduleResult = $"Scheduled {result.EntriesScheduled} entries with {result.WarmUpsAssigned} warm-up slots. " +
                          string.Join("; ", result.BlockSummaries);
        _scheduling = false;

        if (selectedBlockId != Guid.Empty)
            runningOrder = await RunningOrderService.GetForBlockAsync(selectedBlockId);
    }

    private static string RowClass(PerformanceStatus status) => status switch
    {
        PerformanceStatus.Performing => "table-danger",
        PerformanceStatus.OnFloor => "table-primary",
        PerformanceStatus.OnDeck => "table-warning",
        PerformanceStatus.InWarmUp => "table-info",
        PerformanceStatus.Completed => "table-success",
        _ => ""
    };
}
