@page "/public-events"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject EventService EventService

<PageTitle>Upcoming Competitions — CheerDeck</PageTitle>

<div class="container-fluid">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Upcoming Competitions</h1>
        <p class="lead text-muted">Browse open events and register your team</p>
    </div>

    @if (events is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width:3rem;height:3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-3">Loading events...</p>
        </div>
    }
    else if (!events.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3" style="font-size:3rem;">&#128197;</div>
            <h3 class="text-muted">No open events at this time</h3>
            <p class="text-muted">Check back later for upcoming competitions.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var evt in events)
            {
                var daysRemaining = evt.EntryDeadline.DayNumber - DateOnly.FromDateTime(DateTime.UtcNow).DayNumber;
                var firstSessionDate = evt.Sessions.Any()
                    ? evt.Sessions.Min(s => s.Date).ToString("d MMM yyyy")
                    : null;

                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        @* Deadline urgency header *@
                        @if (daysRemaining <= 3)
                        {
                            <div class="card-header bg-danger text-white text-center py-1 fw-semibold small">
                                @if (daysRemaining <= 0)
                                {
                                    <span>Entries close today!</span>
                                }
                                else if (daysRemaining == 1)
                                {
                                    <span>Last day to enter!</span>
                                }
                                else
                                {
                                    <span>Only @daysRemaining days left to enter</span>
                                }
                            </div>
                        }
                        else if (daysRemaining <= 7)
                        {
                            <div class="card-header bg-warning text-dark text-center py-1 fw-semibold small">
                                @daysRemaining days left to enter
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="card-title fw-bold mb-0">@evt.Name</h4>
                                <span class="badge bg-success">Entries Open</span>
                            </div>

                            @if (!string.IsNullOrEmpty(evt.Description))
                            {
                                <p class="card-text text-muted mb-3 small">
                                    @(evt.Description.Length > 120 ? evt.Description[..120] + "..." : evt.Description)
                                </p>
                            }

                            <div class="mb-3 flex-grow-1">
                                @if (!string.IsNullOrEmpty(evt.VenueName))
                                {
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="bi bi-geo-alt text-primary me-2"></i>
                                        <span>@evt.VenueName</span>
                                    </div>
                                }

                                @if (firstSessionDate is not null)
                                {
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="bi bi-calendar-event text-primary me-2"></i>
                                        <span>Event date: <strong>@firstSessionDate</strong></span>
                                    </div>
                                }

                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-clock text-primary me-2"></i>
                                    <span>
                                        Entry deadline: <strong>@evt.EntryDeadline.ToString("d MMM yyyy")</strong>
                                    </span>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-currency-pound text-primary me-2"></i>
                                    <span>Base entry fee: <strong>@evt.BaseEntryFee.ToString("C")</strong></span>
                                </div>

                                @if (evt.Divisions.Any())
                                {
                                    <div class="d-flex align-items-start mb-2">
                                        <i class="bi bi-diagram-3 text-primary me-2 mt-1"></i>
                                        <div>
                                            <span class="small text-muted">@evt.Divisions.Count division@(evt.Divisions.Count == 1 ? "" : "s"):</span>
                                            <div class="mt-1">
                                                @foreach (var div in evt.Divisions.OrderBy(d => d.SortOrder).Take(6))
                                                {
                                                    <span class="badge bg-light text-dark border me-1 mb-1">@div.Name (@div.Level)</span>
                                                }
                                                @if (evt.Divisions.Count > 6)
                                                {
                                                    <span class="badge bg-light text-muted border me-1 mb-1">+@(evt.Divisions.Count - 6) more</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            @* Countdown badge *@
                            <div class="mb-3">
                                @if (daysRemaining <= 7)
                                {
                                    <div class="d-flex align-items-center">
                                        <div class="bg-danger bg-opacity-10 text-danger rounded px-3 py-2 w-100 text-center fw-semibold">
                                            @daysRemaining day@(daysRemaining == 1 ? "" : "s") remaining
                                        </div>
                                    </div>
                                }
                                else if (daysRemaining <= 14)
                                {
                                    <div class="d-flex align-items-center">
                                        <div class="bg-warning bg-opacity-10 text-dark rounded px-3 py-2 w-100 text-center">
                                            @daysRemaining days remaining
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center">
                                        <div class="bg-success bg-opacity-10 text-success rounded px-3 py-2 w-100 text-center">
                                            @daysRemaining days remaining
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <a href="/events/@evt.Id" class="btn btn-outline-primary flex-fill">View Details</a>
                                <a href="/events/@evt.Id/enter" class="btn btn-primary flex-fill fw-semibold">
                                    Submit Entry
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetOpenEventsAsync();
    }
}
