@page "/public-events"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject EventService EventService

<PageTitle>Public Events</PageTitle>

<div class="container-fluid">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Upcoming Competitions</h1>
        <p class="lead text-muted">Browse open events and register your team</p>
    </div>

    @if (events is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!events.Any())
    {
        <div class="text-center py-5">
            <h3 class="text-muted">No open events at this time</h3>
            <p class="text-muted">Check back later for upcoming competitions.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var evt in events)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="card-title fw-bold mb-0">@evt.Name</h4>
                                <span class="badge bg-success">Entries Open</span>
                            </div>

                            @if (!string.IsNullOrEmpty(evt.Description))
                            {
                                <p class="card-text text-muted mb-3">@evt.Description</p>
                            }

                            <div class="mb-3">
                                @if (!string.IsNullOrEmpty(evt.VenueName))
                                {
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="bi bi-geo-alt text-primary me-2"></i>
                                        <span>@evt.VenueName</span>
                                    </div>
                                }

                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-calendar-event text-primary me-2"></i>
                                    <span>Entry deadline: <strong>@evt.EntryDeadline.ToString("d MMM yyyy")</strong></span>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-currency-pound text-primary me-2"></i>
                                    <span>Base entry fee: <strong>@evt.BaseEntryFee.ToString("C")</strong></span>
                                </div>

                                @if (evt.Divisions.Any())
                                {
                                    <div class="d-flex align-items-start mb-2">
                                        <i class="bi bi-diagram-3 text-primary me-2 mt-1"></i>
                                        <div>
                                            <span>Divisions:</span>
                                            <div class="mt-1">
                                                @foreach (var div in evt.Divisions.OrderBy(d => d.SortOrder))
                                                {
                                                    <span class="badge bg-light text-dark border me-1 mb-1">@div.Name (@div.Level)</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mt-auto d-flex gap-2">
                                <a href="/events/@evt.Id" class="btn btn-outline-primary flex-fill">View Details</a>
                                <a href="/events/@evt.Id/enter" class="btn btn-primary flex-fill">Submit Entry</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        var allEvents = await EventService.GetAllAsync();
        events = allEvents.Where(e => e.Status == EventStatus.EntriesOpen).ToList();
    }
}
