@page "/scoring"
@rendermode InteractiveServer
@inject ScoringService ScoringService
@inject EventService EventService

<PageTitle>Scoring</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Scoring</h1>

    @if (events is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label">Event</label>
                <select class="form-select" value="@selectedEventId" @onchange="OnEventSelected">
                    <option value="">-- Select Event --</option>
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.Name</option>
                    }
                </select>
            </div>
            @if (selectedEvent is not null)
            {
                <div class="col-md-4">
                    <label class="form-label">Entry</label>
                    <select class="form-select" value="@selectedEntryId" @onchange="OnEntrySelected">
                        <option value="">-- Select Entry --</option>
                        @foreach (var entry in selectedEvent.Entries)
                        {
                            <option value="@entry.Id">@entry.Team.Name &mdash; @(selectedEvent.Divisions.FirstOrDefault(d => d.Id == entry.DivisionId)?.Name ?? "Unknown")</option>
                        }
                    </select>
                </div>
            }
        </div>

        @if (loadingScoresheet)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span class="ms-2">Loading scoresheet...</span>
            </div>
        }
        else if (selectedEntry is not null && scoresheetTemplate is not null)
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        @selectedEntry.Team.Name &mdash; @scoresheetTemplate.Name
                    </h5>
                    <span class="badge bg-info text-dark">@scoresheetTemplate.Type</span>
                </div>
                <div class="card-body">
                    @foreach (var caption in scoresheetTemplate.Captions.OrderBy(c => c.SortOrder))
                    {
                        <h6 class="mt-3 mb-2 text-uppercase text-muted">
                            @caption.Name
                            <small class="fw-normal">(max @caption.MaxScore, weight @caption.Weight)</small>
                        </h6>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-3">
                                <thead class="table-light">
                                    <tr>
                                        <th>Subcaption</th>
                                        <th style="width:100px">Min</th>
                                        <th style="width:100px">Max</th>
                                        <th style="width:140px">Score</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sub in caption.Subcaptions.OrderBy(s => s.SortOrder))
                                    {
                                        <tr>
                                            <td>@sub.Name</td>
                                            <td class="text-muted">@sub.MinScore</td>
                                            <td class="text-muted">@sub.MaxScore</td>
                                            <td>
                                                <input type="number"
                                                       class="form-control form-control-sm"
                                                       min="@sub.MinScore"
                                                       max="@sub.MaxScore"
                                                       step="@sub.Increment"
                                                       value="@GetScoreValue(sub.Id)"
                                                       @onchange="e => SetScoreValue(sub.Id, e)" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div>
                            @if (submitMessage is not null)
                            {
                                <span class="@(submitSuccess ? "text-success" : "text-danger")">@submitMessage</span>
                            }
                        </div>
                        <button class="btn btn-primary btn-lg" @onclick="SubmitScores" disabled="@submitting">
                            @if (submitting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Submit Scores
                        </button>
                    </div>
                </div>
            </div>
        }
        else if (selectedEntryId != Guid.Empty && scoresheetTemplate is null && !loadingScoresheet)
        {
            <div class="alert alert-warning">No scoresheet template configured for this entry's division.</div>
        }
    }
</div>

@code {
    private List<Event>? events;
    private Event? selectedEvent;
    private Guid selectedEventId;
    private Guid selectedEntryId;
    private EventEntry? selectedEntry;
    private ScoresheetTemplate? scoresheetTemplate;
    private Dictionary<Guid, decimal> scoreValues = new();
    private bool loadingScoresheet;
    private bool submitting;
    private string? submitMessage;
    private bool submitSuccess;
    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetAllAsync();
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        selectedEntry = null;
        selectedEntryId = Guid.Empty;
        scoresheetTemplate = null;
        scoreValues.Clear();
        submitMessage = null;

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedEventId = id;
            selectedEvent = await EventService.GetByIdAsync(id);
        }
        else
        {
            selectedEventId = Guid.Empty;
            selectedEvent = null;
        }
    }

    private void OnEntrySelected(ChangeEventArgs e)
    {
        scoresheetTemplate = null;
        scoreValues.Clear();
        submitMessage = null;

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedEntryId = id;
            selectedEntry = selectedEvent?.Entries.FirstOrDefault(en => en.Id == id);
            if (selectedEntry is not null)
            {
                loadingScoresheet = true;
                var division = selectedEvent!.Divisions.FirstOrDefault(d => d.Id == selectedEntry.DivisionId);
                scoresheetTemplate = division?.ScoresheetTemplates.FirstOrDefault();
                if (scoresheetTemplate is not null)
                {
                    foreach (var caption in scoresheetTemplate.Captions)
                    {
                        foreach (var sub in caption.Subcaptions)
                        {
                            scoreValues[sub.Id] = sub.MinScore;
                        }
                    }
                }
                loadingScoresheet = false;
            }
        }
        else
        {
            selectedEntryId = Guid.Empty;
            selectedEntry = null;
        }
    }

    private string GetScoreValue(Guid subcaptionId)
    {
        return scoreValues.TryGetValue(subcaptionId, out var val) ? val.ToString() : "0";
    }

    private void SetScoreValue(Guid subcaptionId, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            scoreValues[subcaptionId] = val;
        }
    }

    private async Task SubmitScores()
    {
        if (selectedEntry is null || scoresheetTemplate is null) return;

        submitting = true;
        submitMessage = null;

        try
        {
            foreach (var (subcaptionId, value) in scoreValues)
            {
                var score = new Score
                {
                    EntryId = selectedEntry.Id,
                    SubcaptionId = subcaptionId,
                    Value = value,
                    IsOffline = false,
                    ScoredAt = DateTime.UtcNow,
                    Version = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()
                };
                await ScoringService.SubmitScoreAsync(score);
            }

            submitSuccess = true;
            submitMessage = "Scores submitted successfully.";
        }
        catch (Exception ex)
        {
            submitSuccess = false;
            submitMessage = $"Error submitting scores: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }
}
